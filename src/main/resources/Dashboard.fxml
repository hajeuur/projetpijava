<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="mainContainer" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connection3a36.Controller.DashboardController"
            style="-fx-background-color: #f0f4f8;" prefWidth="1200" prefHeight="800">

    <!-- Sidebar Menu -->
    <left>
        <VBox prefWidth="250" spacing="10"
              style="-fx-background-color: linear-gradient(to bottom, #102c59, #0a1a36); -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);">
            <padding><Insets top="30" right="15" bottom="20" left="15"/></padding>

            <!-- Logo Area / App Name -->
            <Label text="MentorAI" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 0 0 20 0; -fx-alignment: center;" maxWidth="Infinity"/>
            <Separator style="-fx-background-color: #9dbbce; -fx-opacity: 0.3;"/>

            <!-- Profil Utilisateur -->
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 15 0 20 0;">
                <Label text="👤" style="-fx-font-size: 28px; -fx-text-fill: #9dbbce;"/>
                <VBox>
                    <Label fx:id="lblUserName" text="Admin" style="-fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label fx:id="lblUserRole" text="ROLE_ADMIN" style="-fx-font-size: 11px; -fx-text-fill: #9dbbce;"/>
                </VBox>
            </HBox>
            <Separator style="-fx-background-color: #9dbbce; -fx-opacity: 0.3; -fx-padding: 0 0 10 0;"/>

            <Label text="NAVIGATION" style="-fx-font-size: 11px; -fx-text-fill: #9dbbce; -fx-padding: 10 0 5 0;"/>

            <!-- Buttons Sidebar -->
            <Button text="📚 Afficher Parcours" onAction="#loadBackOffice" maxWidth="Infinity" alignment="BASELINE_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 15; -fx-cursor: hand;"/>
            
            <Button text="📊 Statistiques" onAction="#loadStats" maxWidth="Infinity" alignment="BASELINE_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 15; -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Logout -->
            <Button text="🚪 Déconnexion" onAction="#logout" maxWidth="Infinity" alignment="CENTER"
                    style="-fx-background-color: transparent; -fx-border-color: #d52e28; -fx-border-radius: 50; -fx-text-fill: #d52e28; -fx-font-size: 13px; -fx-padding: 10; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <!-- Center Content -->
    <center>
        <!-- The loadView() method injects child FXMLs here -->
    </center>

</BorderPane>
