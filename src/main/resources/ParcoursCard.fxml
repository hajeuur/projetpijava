<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:id="cardRoot" spacing="12" 
      fx:controller="edu.connection3a36.controllers.ParcoursCardController"
      style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-border-color: #f1f2f6; -fx-border-radius: 12; -fx-border-width: 1;" 
      prefWidth="350" maxWidth="350" minHeight="450">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <!-- Tag Type -->
    <HBox>
        <Label fx:id="lblTypeTag" text="FORMATION" 
               style="-fx-background-color: #f0f4f8; -fx-text-fill: #102c59; -fx-font-weight: bold; -fx-font-size: 10px; -fx-padding: 4 10; -fx-background-radius: 4;"/>
    </HBox>

    <!-- Title -->
    <Label fx:id="lblTitre" text="Titre du Parcours" wrapText="true"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #102c59;"/>

    <Separator style="-fx-opacity: 0.5;"/>

    <!-- Info Section -->
    <VBox spacing="8">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="🏢" style="-fx-font-size: 14px;"/>
            <Label fx:id="lblEtablissement" text="Établissement" style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="📅" style="-fx-font-size: 14px;"/>
            <Label fx:id="lblDates" text="00/00/0000 - 00/00/0000" style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="🎓" style="-fx-font-size: 14px;"/>
            <Label fx:id="lblDiplome" text="Diplôme" style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;"/>
        </HBox>
    </VBox>

    <!-- Description -->
    <Label fx:id="lblDescription" text="Description courte du parcours..." wrapText="true" VBox.vgrow="ALWAYS"
           style="-fx-text-fill: #34495e; -fx-font-size: 13px; -fx-line-spacing: 1.2;" prefHeight="80" alignment="TOP_LEFT"/>

    <VBox spacing="5">
        <Label text="PROJETS LIÉS" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #95a5a6;"/>
        <FlowPane fx:id="flowPaneProjets" hgap="8" vgap="5">
            <!-- Dynamic tags for related projects -->
            <Label text="📁 Voir projets..." onMouseClicked="#voirProjets"
                   style="-fx-background-color: #f0f4f8; -fx-text-fill: #102c59; -fx-font-size: 11px; -fx-padding: 3 8; -fx-background-radius: 4; -fx-cursor: hand;"/>
        </FlowPane>
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- Action Buttons -->
    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="btnModifier" text="✎ Modifier" onAction="#modifierParcours" 
                style="-fx-background-color: #9dbbce; -fx-text-fill: #102c59; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button fx:id="btnSupprimer" text="🗑 Supprimer" onAction="#supprimerParcours" 
                style="-fx-background-color: transparent; -fx-border-color: #e74c3c; -fx-border-radius: 8; -fx-text-fill: #e74c3c; -fx-font-weight: bold; -fx-padding: 8 20; -fx-cursor: hand;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    </HBox>
</VBox>
