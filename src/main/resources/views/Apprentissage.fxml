<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mentorai.controllers.ApprentissageController"
            styleClass="app-root"
            stylesheets="@../css/apprentissage.css">




    <!-- ═══════════════════════════════════════════════════════════
         CENTER  —  scrollable content panels
         ═══════════════════════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="app-scroll">
            <VBox spacing="20">
                <padding><Insets top="20" right="24" bottom="28" left="24"/></padding>

                <!-- ── Compact page title + search bar ─────────────────── -->
                <HBox alignment="CENTER_LEFT" spacing="16"
                      style="-fx-background-color: linear-gradient(to right,#102c59,#1a3c78); -fx-background-radius:12; -fx-padding: 14 20 14 20;">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="📚  Centre d'apprentissage"
                               style="-fx-text-fill:white; -fx-font-size:17px; -fx-font-weight:bold;"/>
                        <Label text="Explorez vos outils d'apprentissage personnalisés"
                               style="-fx-text-fill:rgba(255,255,255,0.7); -fx-font-size:12px;"/>
                    </VBox>
                    <TextField fx:id="searchField"
                               promptText="🔍  Rechercher…"
                               styleClass="app-search-field"
                               onKeyReleased="#handleSearch"
                               prefWidth="240"
                               style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white; -fx-prompt-text-fill:rgba(255,255,255,0.6); -fx-border-color:rgba(255,255,255,0.3); -fx-border-radius:8; -fx-background-radius:8; -fx-padding:6 12 6 12;"/>
                </HBox>

                <!-- ── Recommandés ─────────────────────────────────────── -->
                <VBox styleClass="section-panel" spacing="14">
                    <!-- Section header with left accent border -->
                    <HBox styleClass="section-header" alignment="CENTER_LEFT">
                        <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>
                        <Label text="⭐  Recommandés pour vous" styleClass="section-title" />
                    </HBox>
                    <HBox fx:id="recommendedContainer" styleClass="h-card-row" spacing="16" />
                </VBox>

                <!-- ── Récents ──────────────────────────────────────────── -->
                <VBox styleClass="section-panel" spacing="14">
                    <HBox styleClass="section-header" alignment="CENTER_LEFT">
                        <Label text="🕐  Services récents" styleClass="section-title" />
                    </HBox>
                    <HBox fx:id="recentContainer" styleClass="h-card-row" spacing="16" />
                </VBox>

                <!-- ── Catégories ──────────────────────────────────────── -->
                <VBox fx:id="categoriesContainer" spacing="24">

                    <!-- Génération de contenu -->
                    <VBox styleClass="section-panel" spacing="14">
                        <HBox styleClass="section-header" alignment="CENTER_LEFT" spacing="10">
                            <Label text="✨" styleClass="category-icon" />
                            <Label text="Génération de contenu" styleClass="category-title" />
                        </HBox>
                        <FlowPane fx:id="contentGenGrid" hgap="16" vgap="16" styleClass="card-grid" />
                    </VBox>

                    <!-- Analyse &amp; Intelligence -->
                    <VBox styleClass="section-panel" spacing="14">
                        <HBox styleClass="section-header" alignment="CENTER_LEFT" spacing="10">
                            <Label text="🧠" styleClass="category-icon" />
                            <Label text="Analyse &amp; Intelligence" styleClass="category-title" />
                        </HBox>
                        <FlowPane fx:id="analysisGrid" hgap="16" vgap="16" styleClass="card-grid" />
                    </VBox>

                    <!-- Productivité &amp; Planification -->
                    <VBox styleClass="section-panel" spacing="14">
                        <HBox styleClass="section-header" alignment="CENTER_LEFT" spacing="10">
                            <Label text="📅" styleClass="category-icon" />
                            <Label text="Productivité &amp; Planification" styleClass="category-title" />
                        </HBox>
                        <FlowPane fx:id="productivityGrid" hgap="16" vgap="16" styleClass="card-grid" />
                    </VBox>

                    <!-- Ressources -->
                    <VBox styleClass="section-panel" spacing="14">
                        <HBox styleClass="section-header" alignment="CENTER_LEFT" spacing="10">
                            <Label text="📚" styleClass="category-icon" />
                            <Label text="Ressources" styleClass="category-title" />
                        </HBox>
                        <FlowPane fx:id="resourcesGrid" hgap="16" vgap="16" styleClass="card-grid" />
                    </VBox>

                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
