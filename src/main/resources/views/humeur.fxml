<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mentorai.controllers.HumeurController"
            styleClass="root-pane"
            stylesheets="@../css/Humeur.css">

    <!-- ================= HEADER ================= -->
    <top>
        <VBox styleClass="header" alignment="CENTER_LEFT">
            <Label fx:id="greetingLabel" styleClass="header-greeting" text="Bonjour 👋" />
            <Label styleClass="header-subtitle" text="Comment vous sentez-vous aujourd'hui ?" />
        </VBox>
    </top>

    <!-- ================= CENTER (SCROLLABLE) ================= -->
    <center>
        <ScrollPane styleClass="main-scroll" fitToWidth="true">
            <HBox styleClass="main-hbox" spacing="24" alignment="TOP_LEFT">

                <!-- ========= SIDEBAR (statistiques) ========= -->
                <VBox styleClass="sidebar" spacing="20" prefWidth="260">

                    <!-- Carte Humeur moyenne 7j -->
                    <VBox styleClass="stat-card">
                        <Label styleClass="stat-title" text="HUMEUR MOYENNE (7J)" />
                        <Label fx:id="moyenne7Label" styleClass="stat-value" text="—" />
                    </VBox>

                    <!-- Carte Meilleure série -->
                    <VBox styleClass="stat-card">
                        <Label styleClass="stat-title" text="MEILLEURE SÉRIE" />
                        <Label fx:id="streakLabel" styleClass="stat-value" text="🔥 0 jour" />
                    </VBox>

                    <!-- Carte Humeur du jour (statique) -->
                    <VBox styleClass="stat-card mood-today-card">
                        <Label styleClass="stat-title" text="HUMEUR DU JOUR" />
                        <Label fx:id="emojiLabel" styleClass="emoji-big" text="❓" />
                        <Label fx:id="moodLabelToday" styleClass="mood-label-today" text="Non renseignée" />
                    </VBox>

                    <!-- Carte Niveau de risque -->
                    <VBox styleClass="stat-card">
                        <Label styleClass="stat-title" text="NIVEAU DE RISQUE" />
                        <Label fx:id="risqueLabel" styleClass="stat-value" text="—" />
                    </VBox>

                </VBox>

                <!-- ========= MAIN AREA (contenu dynamique) ========= -->
                <VBox spacing="24" HBox.hgrow="ALWAYS">

                    <!-- Bannière "Aujourd'hui" -->
                    <HBox styleClass="today-banner" alignment="CENTER_LEFT" spacing="20">
                        <VBox HBox.hgrow="ALWAYS" spacing="8">
                            <Label fx:id="todaySummaryLabel" styleClass="today-summary-main" text="Aucune humeur enregistrée" />
                            <Label fx:id="todayTagsLabel" styleClass="today-summary-tags" text="" />
                            <Label fx:id="todayJournalLabel" styleClass="today-summary-journal" text="" wrapText="true" />
                        </VBox>
                        <Label fx:id="todayEmojiLarge" styleClass="today-emoji-large" text="🌤️" />
                    </HBox>

                    <!-- Graphique d'évolution -->
                    <VBox styleClass="chart-card" spacing="12">
                        <Label styleClass="section-title" text="ÉVOLUTION DE L'HUMEUR (14 derniers jours)" />
                        <LineChart fx:id="moodChart" styleClass="mood-line-chart" animated="false" createSymbols="true" legendVisible="false">
                            <xAxis>
                                <CategoryAxis fx:id="chartXAxis" label="Date" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis fx:id="chartYAxis" label="Humeur (1-5)" tickUnit="1" lowerBound="1" upperBound="5" />
                            </yAxis>
                        </LineChart>
                    </VBox>

                    <!-- Formulaire d'ajout / modification -->
                    <VBox styleClass="form-card" spacing="16">
                        <Label styleClass="section-title" text="AJOUTER / MODIFIER L'HUMEUR" />

                        <!-- Slider avec valeur et emoji en direct -->
                        <VBox spacing="6">
                            <Label styleClass="form-label" text="Votre humeur (1 = très mal → 5 = très bien)" />
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Slider fx:id="humeurSlider" styleClass="mood-slider" min="1" max="5" majorTickUnit="1" minorTickCount="0" snapToTicks="true" showTickLabels="true" blockIncrement="1" HBox.hgrow="ALWAYS" />
                                <Label fx:id="sliderValueLabel" styleClass="slider-live-value" text="3" />
                                <Label fx:id="sliderEmojiInline" styleClass="slider-live-emoji" text="😐" />
                            </HBox>
                        </VBox>

                        <!-- Facteur principal (journal) -->
                        <VBox spacing="6">
                            <Label styleClass="form-label" text="Facteur principal / journal (max 150 caractères)" />
                            <TextArea fx:id="facteurField" styleClass="form-textarea" prefRowCount="3" wrapText="true" />
                            <Label fx:id="facteurCountLabel" styleClass="char-counter" text="0 / 150" alignment="TOP_RIGHT" />
                        </VBox>

                        <!-- Tags (CheckBox, max 3 sélectionnables) -->
                        <VBox spacing="6">
                            <Label styleClass="form-label" text="Tags (max 3)" />
                            <FlowPane hgap="12" vgap="8">
                                <CheckBox fx:id="tagStress" styleClass="tag-check" text="Stress" />
                                <CheckBox fx:id="tagSommeil" styleClass="tag-check" text="Sommeil" />
                                <CheckBox fx:id="tagTravail" styleClass="tag-check" text="Travail" />
                                <CheckBox fx:id="tagSocial" styleClass="tag-check" text="Social" />
                                <CheckBox fx:id="tagSanté" styleClass="tag-check" text="Santé" />
                                <CheckBox fx:id="tagSport" styleClass="tag-check" text="Sport" />
                                <CheckBox fx:id="tagAlimentation" styleClass="tag-check" text="Alimentation" />
                                <CheckBox fx:id="tagFocus" styleClass="tag-check" text="Focus" />
                            </FlowPane>
                        </VBox>

                        <!-- Boutons d'action -->
                        <HBox spacing="12" alignment="CENTER_RIGHT">
                            <Button fx:id="ajouterBtn" styleClass="btn-primary" text="Enregistrer l'humeur" onAction="#ajouterHumeur" />
                            <Button fx:id="updateBtn" styleClass="btn-secondary" text="Modifier l'humeur" onAction="#updateHumeur" visible="false" />
                            <Button styleClass="btn-ghost" text="Rafraîchir" onAction="#loadStats" />
                        </HBox>

                        <!-- Zone d'affichage des erreurs -->
                        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" visible="false" />
                    </VBox>
                </VBox>
            </HBox>
        </ScrollPane>
    </center>

    <!-- ================= STATUS BAR ================= -->
    <bottom>
        <HBox styleClass="statusbar" alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="statusLabel" styleClass="statusbar-label" text="Prêt" />
        </HBox>
    </bottom>

</BorderPane>