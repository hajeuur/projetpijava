<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mentorai.controllers.HumeurController"
            styleClass="root-pane"
            stylesheets="@../css/Humeur.css">

    <!-- ================= HEADER ================= -->
    <top>
        <VBox styleClass="header" alignment="CENTER_LEFT">
            <Label fx:id="greetingLabel" styleClass="header-greeting" text="Bonjour 👋" />
            <Label styleClass="header-subtitle" text="Comment vous sentez-vous aujourd'hui ?" />
        </VBox>
    </top>

    <!-- ================= CENTER (SCROLLABLE) ================= -->
    <!-- ================= CENTER (STACKPANE FOR VIEW SWITCHING) ================= -->
    <center>
        <StackPane>
            <!-- ========= DASHBOARD VIEW ========= -->
            <ScrollPane fx:id="dashboardView" styleClass="main-scroll" fitToWidth="true">
                <VBox spacing="24">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <Label styleClass="section-title" text="Tableau de bord de bien-être" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="mainActionButton" styleClass="btn-primary" text="➕ Ajouter humeur" onAction="#handleMainAction" />
                    </HBox>

                    <HBox styleClass="main-hbox" spacing="24" alignment="TOP_LEFT">
                        <VBox styleClass="sidebar" spacing="20" prefWidth="260">
                            <VBox styleClass="stat-card">
                                <Label styleClass="stat-title" text="HUMEUR MOYENNE (7J)" />
                                <Label fx:id="moyenne7Label" styleClass="stat-value" text="—" />
                            </VBox>
                            <VBox styleClass="stat-card">
                                <Label styleClass="stat-title" text="MEILLEURE SÉRIE" />
                                <Label fx:id="streakLabel" styleClass="stat-value" text="🔥 0 jour" />
                            </VBox>
                            <VBox styleClass="stat-card">
                                <Label styleClass="stat-title" text="NIVEAU DE RISQUE" />
                                <Label fx:id="risqueLabel" styleClass="stat-value" text="—" />
                            </VBox>
                        </VBox>

                        <VBox spacing="24" HBox.hgrow="ALWAYS">
                            <HBox styleClass="today-banner" alignment="CENTER_LEFT" spacing="20">
                                <VBox HBox.hgrow="ALWAYS" spacing="8">
                                    <Label fx:id="todaySummaryLabel" styleClass="today-summary-main" text="Aucune humeur enregistrée" />
                                    <Label fx:id="todayTagsLabel" styleClass="today-summary-tags" text="" />
                                    <Label fx:id="todayJournalLabel" styleClass="today-summary-journal" text="" wrapText="true" />
                                </VBox>
                                <Label fx:id="todayEmojiLarge" styleClass="today-emoji-large" text="🌤️" />
                            </HBox>

                            <VBox styleClass="chart-card" spacing="12">
                                <Label styleClass="section-title" text="ÉVOLUTION DE L'HUMEUR (14 derniers jours)" />
                                <LineChart fx:id="moodChart" styleClass="mood-line-chart" animated="false" createSymbols="true" legendVisible="false">
                                    <xAxis><CategoryAxis fx:id="chartXAxis" /></xAxis>
                                    <yAxis><NumberAxis fx:id="chartYAxis" lowerBound="1" upperBound="5" tickUnit="1" /></yAxis>
                                </LineChart>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>

            <!-- ========= GUIDED FLOW VIEW ========= -->
            <VBox fx:id="guidedFlowView" visible="false" managed="false" alignment="CENTER" spacing="30" style="-fx-background-color: #f8fafc;">
                <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

                <VBox alignment="CENTER" spacing="10">
                    <Label fx:id="stepIndicatorLabel" styleClass="step-indicator" text="Étape 1 sur 2" />
                    <Label fx:id="stepTitleLabel" styleClass="step-title" text="Comment vous sentez-vous ?" />
                </VBox>

                <StackPane fx:id="stepsContainer" VBox.vgrow="ALWAYS" maxWidth="600">
                    <VBox fx:id="step1" spacing="40" alignment="CENTER">
                        <VBox alignment="CENTER" spacing="20">
                            <Label fx:id="sliderEmojiInline" style="-fx-font-size: 80px;" text="😐" />
                            <Label fx:id="sliderValueLabel" styleClass="slider-big-value" text="3" />
                        </VBox>
                        <Slider fx:id="humeurSlider" min="1" max="5" majorTickUnit="1" minorTickCount="0" snapToTicks="true" showTickLabels="true" blockIncrement="1" maxWidth="400" />
                    </VBox>

                    <!-- Step 2: Tags (Replaces the old Factor text step) -->
                    <VBox fx:id="step2" visible="false" managed="false" spacing="20" alignment="CENTER">
                        <Label styleClass="form-label" text="Quels sont les facteurs principaux ? (max 3)" />
                        <FlowPane hgap="15" vgap="15" alignment="CENTER" maxWidth="500">
                            <CheckBox fx:id="tagStress" styleClass="tag-check" text="Stress" />
                            <CheckBox fx:id="tagSommeil" styleClass="tag-check" text="Sommeil" />
                            <CheckBox fx:id="tagTravail" styleClass="tag-check" text="Travail" />
                            <CheckBox fx:id="tagSocial" styleClass="tag-check" text="Social" />
                            <CheckBox fx:id="tagSanté" styleClass="tag-check" text="Santé" />
                            <CheckBox fx:id="tagSport" styleClass="tag-check" text="Sport" />
                            <CheckBox fx:id="tagAlimentation" styleClass="tag-check" text="Alimentation" />
                            <CheckBox fx:id="tagFocus" styleClass="tag-check" text="Focus" />
                        </FlowPane>
                    </VBox>
                </StackPane>

                <HBox spacing="20" alignment="CENTER">
                    <Button fx:id="btnPrev" text="Précédent" onAction="#prevStep" styleClass="btn-secondary" />
                    <Button fx:id="btnNext" text="Suivant" onAction="#nextStep" styleClass="btn-primary" />
                    <Button fx:id="btnSubmit" text="Terminer" onAction="#ajouterHumeur" styleClass="btn-primary" visible="false" managed="false" />
                    <Button text="Annuler" onAction="#showDashboard" styleClass="btn-ghost" />
                </HBox>

                <Label fx:id="errorLabel" styleClass="error-label" visible="false" />
            </VBox>
        </StackPane>
    </center>

    <!-- ================= STATUS BAR ================= -->
    <bottom>
        <HBox styleClass="statusbar" alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="statusLabel" styleClass="statusbar-label" text="Prêt" />
        </HBox>
    </bottom>

</BorderPane>