<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mentorai.controllers.HumeurController"
            styleClass="humeur-root"
            stylesheets="@../css/Humeur.css">

    <!-- ═══════════════════════════════════════════════════════════
         HEADER  —  navy banner matching Feedback's #102c59 bar
         ═══════════════════════════════════════════════════════════ -->
    <top>
        <VBox styleClass="humeur-header" alignment="CENTER_LEFT">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label fx:id="greetingLabel" styleClass="header-greeting" text="Bonjour 👋" />
                    <Label styleClass="header-subtitle" text="Comment vous sentez-vous aujourd'hui ?" />
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════════
         CENTER  —  StackPane switches between Dashboard / Guided
         ═══════════════════════════════════════════════════════════ -->
    <center>
        <StackPane>

            <!-- ── DASHBOARD VIEW ──────────────────────────────────── -->
            <ScrollPane fx:id="dashboardView" styleClass="humeur-scroll" fitToWidth="true">
                <VBox spacing="20">
                    <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

                    <!-- Top bar: section title + action button -->
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label styleClass="page-title" text="Tableau de bord — Bien-être" />
                            <Label styleClass="page-subtitle" text="Suivez votre humeur et votre énergie au quotidien" />
                        </VBox>
                        <Button fx:id="mainActionButton"
                                styleClass="btn-primary-pill"
                                text="➕  Ajouter humeur"
                                onAction="#handleMainAction" />
                    </HBox>

                    <!-- Stat cards row -->
                    <HBox spacing="16" alignment="TOP_LEFT">

                        <!-- Card: 7-day average -->
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <Label styleClass="stat-label" text="HUMEUR MOYENNE (7J)" />
                            <Label fx:id="moyenne7Label" styleClass="stat-big" text="—" />
                        </VBox>

                        <!-- Card: streak -->
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <Label styleClass="stat-label" text="MEILLEURE SÉRIE" />
                            <Label fx:id="streakLabel" styleClass="stat-big" text="🔥  0 jour" />
                        </VBox>

                        <!-- Card: risk -->
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <Label styleClass="stat-label" text="NIVEAU DE RISQUE" />
                            <Label fx:id="risqueLabel" styleClass="stat-big" text="—" />
                        </VBox>

                    </HBox>

                    <!-- Today banner -->
                    <VBox styleClass="today-card" spacing="10">
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <VBox HBox.hgrow="ALWAYS" spacing="5">
                                <Label styleClass="card-section-title" text="Aujourd'hui" />
                                <Label fx:id="todaySummaryLabel" styleClass="today-main-text" text="Aucune humeur enregistrée" />
                                <Label fx:id="todayTagsLabel"    styleClass="today-tags-text" text="" />
                                <Label fx:id="todayJournalLabel" styleClass="today-journal-text" text="" wrapText="true" />
                            </VBox>
                            <Label fx:id="todayEmojiLarge" styleClass="today-emoji" text="🌤️" />
                        </HBox>
                    </VBox>

                    <!-- Chart card -->
                    <VBox styleClass="chart-panel" spacing="12">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label styleClass="card-section-title" text="Évolution de l'humeur" />
                                <Label styleClass="card-section-sub"  text="14 derniers jours" />
                            </VBox>
                        </HBox>
                        <LineChart fx:id="moodChart" styleClass="mood-line-chart"
                                   animated="false" createSymbols="true" legendVisible="false"
                                   prefHeight="220">
                            <xAxis><CategoryAxis fx:id="chartXAxis" /></xAxis>
                            <yAxis><NumberAxis fx:id="chartYAxis" lowerBound="1" upperBound="5" tickUnit="1" /></yAxis>
                        </LineChart>
                    </VBox>

                </VBox>
            </ScrollPane>

            <!-- ── GUIDED FLOW VIEW ─────────────────────────────────── -->
            <VBox fx:id="guidedFlowView" visible="false" managed="false"
                  styleClass="guided-bg" alignment="CENTER" spacing="32">
                <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

                <!-- Step indicator -->
                <VBox alignment="CENTER" spacing="8">
                    <Label fx:id="stepIndicatorLabel" styleClass="step-badge" text="Étape 1 sur 2" />
                    <Label fx:id="stepTitleLabel"     styleClass="step-headline" text="Comment vous sentez-vous ?" />
                </VBox>

                <!-- Steps container -->
                <StackPane fx:id="stepsContainer" VBox.vgrow="ALWAYS" maxWidth="560">

                    <!-- Step 1: Slider -->
                    <VBox fx:id="step1" spacing="32" alignment="CENTER">
                        <VBox styleClass="step-card" alignment="CENTER" spacing="16">
                            <Label fx:id="sliderEmojiInline" styleClass="step-emoji-large" text="😐" />
                            <Label fx:id="sliderValueLabel"  styleClass="step-value-large" text="3" />
                            <Slider fx:id="humeurSlider"
                                    min="1" max="5"
                                    majorTickUnit="1" minorTickCount="0"
                                    snapToTicks="true" showTickLabels="true"
                                    blockIncrement="1"
                                    styleClass="humeur-slider"
                                    maxWidth="360" />
                        </VBox>
                    </VBox>

                    <!-- Step 2: Tags -->
                    <VBox fx:id="step2" visible="false" managed="false"
                          spacing="20" alignment="CENTER">
                        <VBox styleClass="step-card" spacing="16" alignment="CENTER">
                            <Label styleClass="step-field-label"
                                   text="Quels sont les facteurs principaux ? (max 3)" />
                            <FlowPane hgap="12" vgap="12" alignment="CENTER" maxWidth="480">
                                <CheckBox fx:id="tagStress"        styleClass="tag-chip" text="😰  Stress" />
                                <CheckBox fx:id="tagSommeil"       styleClass="tag-chip" text="😴  Sommeil" />
                                <CheckBox fx:id="tagTravail"       styleClass="tag-chip" text="💼  Travail" />
                                <CheckBox fx:id="tagSocial"        styleClass="tag-chip" text="👥  Social" />
                                <CheckBox fx:id="tagSanté"         styleClass="tag-chip" text="❤️  Santé" />
                                <CheckBox fx:id="tagSport"         styleClass="tag-chip" text="🏃  Sport" />
                                <CheckBox fx:id="tagAlimentation"  styleClass="tag-chip" text="🥗  Alimentation" />
                                <CheckBox fx:id="tagFocus"         styleClass="tag-chip" text="🎯  Focus" />
                            </FlowPane>
                        </VBox>
                    </VBox>

                </StackPane>

                <!-- Navigation buttons -->
                <HBox spacing="16" alignment="CENTER">
                    <Button fx:id="btnPrev"   text="← Précédent" onAction="#prevStep"    styleClass="btn-outline-pill" />
                    <Button fx:id="btnNext"   text="Suivant →"   onAction="#nextStep"    styleClass="btn-primary-pill" />
                    <Button fx:id="btnSubmit" text="✔ Terminer"  onAction="#ajouterHumeur" styleClass="btn-primary-pill"
                            visible="false" managed="false" />
                    <Button text="Annuler" onAction="#showDashboard" styleClass="btn-ghost-pill" />
                </HBox>

                <Label fx:id="errorLabel" styleClass="inline-error" visible="false" />
            </VBox>

        </StackPane>
    </center>

    <!-- ═══════════════════════════════════════════════════════════
         BOTTOM  —  slim status bar
         ═══════════════════════════════════════════════════════════ -->
    <bottom>
        <HBox styleClass="humeur-statusbar" alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="statusLabel" styleClass="statusbar-text" text="Prêt" />
        </HBox>
    </bottom>

</BorderPane>