<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<StackPane style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <HBox alignment="CENTER" spacing="50">
        <padding><Insets top="50" right="50" bottom="50" left="50"/></padding>
        
        <VBox alignment="CENTER_LEFT" spacing="20" maxWidth="500">
            <Label text="Transform Your Future" style="-fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="Discover thousands of high-quality courses designed by industry professionals. Learn at your own pace, gain in-demand skills, and advance your career." 
                   wrapText="true" style="-fx-font-size: 16; -fx-text-fill: #64748b;"/>
            
            <HBox spacing="20">
                <Button text="Browse Courses" style="-fx-background-color: #9dbbce; -fx-text-fill: #102c59; -fx-font-size: 14; -fx-padding: 12 25; -fx-background-radius: 25; -fx-cursor: hand;"/>
                <Button text="Learn More" style="-fx-background-color: transparent; -fx-border-color: #f87171; -fx-text-fill: #f87171; -fx-font-size: 14; -fx-padding: 12 25; -fx-background-radius: 25; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
        
        <ImageView fitWidth="500" preserveRatio="true">
            <image>
                <!-- Image placeholder or use the screenshot as reference -->
                <Image url="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?ixlib=rb-1.2.1&amp;auto=format&amp;fit=crop&amp;w=800&amp;q=80"/>
            </image>
        </ImageView>
    </HBox>
</StackPane>
