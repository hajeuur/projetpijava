<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connection3a36.controllers.PreferencesController"
      spacing="20">

    <!-- ===== PAGE HEADER ===== -->
    <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="⚙️ Préférences" styleClass="section-title"/>
            <Label text="Personnalisez votre expérience MentorAI"
                   styleClass="section-subtitle"/>
        </VBox>
        <Button text="💾 Enregistrer" onAction="#handleSave" styleClass="btn-success"/>
        <Button text="↩️ Réinitialiser"  onAction="#handleReset" styleClass="btn-secondary"/>
    </HBox>

    <!-- ===== APPARENCE ===== -->
    <VBox styleClass="card" spacing="14">
        <Label text="🎨 Apparence" styleClass="pref-title"/>
        <Separator/>

        <!-- Dark Mode -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox HBox.hgrow="ALWAYS" spacing="3">
                <Label text="Mode Sombre (Dark Mode)" styleClass="pref-title"/>
                <Label text="Interface avec fond foncé pour réduire la fatigue visuelle"
                       styleClass="pref-desc"/>
            </VBox>
            <CheckBox fx:id="chkDarkMode"/>
        </HBox>

        <Separator style="-fx-opacity: 0.4;"/>

        <!-- Grande Police -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox HBox.hgrow="ALWAYS" spacing="3">
                <Label text="Grande Taille de Police" styleClass="pref-title"/>
                <Label text="Augmente la taille du texte pour une meilleure lisibilité"
                       styleClass="pref-desc"/>
            </VBox>
            <CheckBox fx:id="chkLargeText"/>
        </HBox>

        <Separator style="-fx-opacity: 0.4;"/>

        <!-- Mode Dyslexique -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox HBox.hgrow="ALWAYS" spacing="3">
                <Label text="Mode Dyslexique" styleClass="pref-title"/>
                <Label text="Utilise une police adaptée aux personnes dyslexiques (OpenDyslexic)"
                       styleClass="pref-desc"/>
            </VBox>
            <CheckBox fx:id="chkDyslexic"/>
        </HBox>
    </VBox>

    <!-- ===== INFORMATION ===== -->
    <VBox styleClass="card" spacing="10">
        <Label text="ℹ️ À propos de MentorAI" styleClass="pref-title"/>
        <Separator/>
        <HBox spacing="30">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Version"  style="-fx-font-weight: bold; -fx-text-fill: #102c59;"/>
                <Label text="MentorAI v3.0 — Java 17 + JavaFX 21"
                       style="-fx-text-fill: #7a8fa5; -fx-font-size: 12px;"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="IA Utilisée" style="-fx-font-weight: bold; -fx-text-fill: #102c59;"/>
                <Label text="Groq API — LLaMA 3.1 8B Instant"
                       style="-fx-text-fill: #7a8fa5; -fx-font-size: 12px;"/>
            </VBox>
        </HBox>
        <Label fx:id="lblVersion"
               text="École ESPRIT — Module Gestion Interne Admin &amp; Enseignant"
               style="-fx-text-fill: #9dbbce; -fx-font-size: 12px;"/>
    </VBox>

    <!-- ===== COMPTE ===== -->
    <VBox styleClass="card" spacing="10">
        <Label text="👤 Mon Compte" styleClass="pref-title"/>
        <Separator/>
        <Label fx:id="lblUserInfo" text="" style="-fx-text-fill: #102c59; -fx-font-size: 13px;"/>
        <Button text="🚪 Se déconnecter" onAction="#handleLogout" styleClass="btn-danger"
                style="-fx-padding: 8 20; -fx-alignment: CENTER-LEFT;"/>
    </VBox>

</VBox>
