<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="edu.connection3a36.controllers.LoginController"
           styleClass="login-root">

    <!-- Background décoratif -->
    <VBox alignment="CENTER" spacing="0" maxWidth="1200" maxHeight="800">

        <!-- Carte login centrée -->
        <VBox alignment="CENTER">

            <VBox styleClass="login-card" maxWidth="420" alignment="CENTER" spacing="0">

                <!-- Logo + titre -->
                <VBox alignment="CENTER" spacing="6" style="-fx-padding: 0 0 20 0;">
                    <Label text="🎓 MentorAI" styleClass="login-logo"/>
                    <Label text="Plateforme de Gestion Pédagogique" styleClass="login-logo-sub"/>
                    <Label text="Connexion à votre espace"
                           style="-fx-font-size: 12px; -fx-text-fill: #b0b3c7; -fx-padding: 4 0 0 0;"/>
                </VBox>

                <Separator style="-fx-padding: 0 0 20 0;"/>

                <!-- Champs -->
                <VBox spacing="16" style="-fx-padding: 20 0 0 0;">

                    <VBox spacing="5">
                        <Label text="Adresse Email" styleClass="login-field-label"/>
                        <TextField fx:id="tfEmail" promptText="admin@esprit.tn"
                                   maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Mot de passe" styleClass="login-field-label"/>
                        <PasswordField fx:id="tfMdp" promptText="••••••••"
                                       maxWidth="Infinity"/>
                    </VBox>

                    <Label fx:id="lblError" text="" styleClass="error-label"
                           visible="false" managed="false" wrapText="true"/>

                    <Button text="Se connecter →" onAction="#handleLogin"
                            styleClass="login-btn" maxWidth="Infinity"/>

                </VBox>

                <!-- Note de bas de page -->
                <Label text="Accès sécurisé — ESPRIT School of Engineering"
                       style="-fx-font-size: 10px; -fx-text-fill: #c8cad8; -fx-padding: 18 0 0 0;"
                       textAlignment="CENTER" wrapText="true" maxWidth="340"/>

            </VBox>
        </VBox>
    </VBox>

</StackPane>
