<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane styleClass="login-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connection3a36.controllers.LoginController">
    <stylesheets>
        <URL value="@/css/styles.css" />
    </stylesheets>

    <!-- Decorative Shapes (Modern UI trend) -->
    <Region maxHeight="400" maxWidth="400" style="-fx-background-color: rgba(255,255,255,0.03); -fx-background-radius: 200; -fx-translate-x: -300; -fx-translate-y: -200;" />
    <Region maxHeight="300" maxWidth="300" style="-fx-background-color: rgba(255,255,255,0.02); -fx-background-radius: 150; -fx-translate-x: 400; -fx-translate-y: 250;" />

    <!-- Main Container -->
    <VBox alignment="CENTER" spacing="0">
        <!-- Login Card -->
        <VBox alignment="CENTER" maxWidth="450" spacing="0" styleClass="login-card">
            
            <!-- Brand Identity -->
            <VBox alignment="CENTER" spacing="10" style="-fx-padding: 0 0 35 0;">
                <Label styleClass="login-logo" text="🎓 MentorAI" />
                <Label styleClass="login-logo-sub" text="PLATEFORME DE GESTION PÉDAGOGIQUE" style="-fx-letter-spacing: 2; -fx-font-weight: bold; -fx-font-size: 11;" />
                <Region style="-fx-background-color: #3b82f6; -fx-pref-height: 3; -fx-max-width: 50; -fx-background-radius: 2;" />
            </VBox>

            <!-- Login Form -->
            <VBox spacing="25" style="-fx-padding: 10 10 0 10;">
                <VBox spacing="8">
                    <Label styleClass="login-field-label" text="Adresse Email" />
                    <TextField fx:id="tfEmail" maxWidth="Infinity" promptText="Saisissez votre email professionnel" 
                               style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;" />
                </VBox>

                <VBox spacing="8">
                    <Label styleClass="login-field-label" text="Mot de passe" />
                    <PasswordField fx:id="tfMdp" maxWidth="Infinity" promptText="••••••••••••" 
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;" />
                </VBox>

                <!-- Error Message -->
                <Label fx:id="lblError" managed="false" styleClass="error-label" text="" visible="false" wrapText="true" 
                       style="-fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-alignment: CENTER;" />

                <Button defaultButton="true" maxWidth="Infinity" onAction="#handleLogin" styleClass="login-btn" text="Se connecter au tableau de bord" />

                <HBox alignment="CENTER" spacing="10">
                    <Separator HBox.hgrow="ALWAYS" style="-fx-opacity: 0.3;" />
                    <Label text="SÉCURISÉ" style="-fx-text-fill: #94a3b8; -fx-font-size: 9; -fx-font-weight: bold;" />
                    <Separator HBox.hgrow="ALWAYS" style="-fx-opacity: 0.3;" />
                </HBox>

                <HBox alignment="CENTER" spacing="20" style="-fx-padding: 5 0 0 0;">
                    <Button onAction="#loginAsStudent" text="👤 Accès Étudiant" 
                            style="-fx-background-color: transparent; -fx-text-fill: #3b82f6; -fx-font-size: 11; -fx-cursor: hand; -fx-font-weight: bold;" />
                    <Button onAction="#loginAsAdmin" text="🛠 Accès Admin" 
                            style="-fx-background-color: transparent; -fx-text-fill: #ef4444; -fx-font-size: 11; -fx-cursor: hand; -fx-font-weight: bold;" />
                </HBox>
            </VBox>

            <!-- Footer -->
            <VBox alignment="CENTER" spacing="5" style="-fx-padding: 35 0 0 0;">
                <Label style="-fx-font-size: 11; -fx-text-fill: #64748b;" text="Accès réservé aux membres de l'institution" />
                <Label style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" text="© ESPRIT SCHOOL OF ENGINEERING" />
            </VBox>
        </VBox>
    </VBox>
</StackPane>
