<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mentorai.controllers.TraiterFeedbackController"
      spacing="0"
      style="-fx-background-color: #f5f7fa;"
      prefWidth="620" prefHeight="850">

    <!-- HEADER -->
    <HBox style="-fx-background-color: #102c59; -fx-padding: 16 20 16 20;"
          alignment="CENTER_LEFT" spacing="10">
        <Label text="Traiter le Feedback"
               style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        <VBox spacing="2">
            <Label fx:id="labelSousTitre" text="Feedback #..."
                   style="-fx-text-fill: #9dbbce; -fx-font-size: 11px;"/>
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox spacing="15" style="-fx-padding: 20;">

            <!-- INFO FEEDBACK -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),5,0,0,2);
                         -fx-padding: 0;">
                <HBox style="-fx-background-color: #eef2ff; -fx-padding: 10 15 10 15;
                             -fx-background-radius: 8 8 0 0;" alignment="CENTER_LEFT" spacing="8">
                    <Label text="📋 Informations du Feedback"
                           style="-fx-font-weight: bold; -fx-text-fill: #102c59; -fx-font-size: 12px;"/>
                </HBox>
                <VBox style="-fx-padding: 12 15 12 15;" spacing="6">
                    <Label fx:id="labelInfoFeedback" text="..."
                           wrapText="true"
                           style="-fx-text-fill: #444; -fx-font-size: 12px;"/>
                </VBox>
            </VBox>

            <!-- ANALYSE DE SENTIMENT AZURE IA -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 10;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.12),8,0,0,3);
                         -fx-padding: 0;">
                <HBox style="-fx-background-color: linear-gradient(to right, #0078d4, #00bcf2); 
                             -fx-padding: 14 20 14 20;
                             -fx-background-radius: 10 10 0 0;" alignment="CENTER_LEFT" spacing="10">
                    <Label text="🧠"
                           style="-fx-font-size: 20px;"/>
                    <VBox spacing="2">
                        <Label text="Analyse d'Émotions par Intelligence Artificielle"
                               style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 13px;"/>
                        <Label text="Propulsé par Azure Cognitive Services"
                               style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 10px;"/>
                    </VBox>
                </HBox>
                
                <VBox spacing="16" style="-fx-padding: 20;">
                    
                    <!-- Sentiment principal avec design amélioré -->
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="Sentiment détecté :"
                               style="-fx-font-size: 12px; -fx-text-fill: #666; -fx-font-weight: bold;"/>
                        <Label fx:id="labelSentimentPrincipal" text="😐 NEUTRE"
                               style="-fx-background-color: #f0a500; -fx-text-fill: white;
                                      -fx-padding: 8 16 8 16; -fx-background-radius: 20;
                                      -fx-font-size: 14px; -fx-font-weight: bold;
                                      -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.2),4,0,0,2);"/>
                    </HBox>
                    
                    <!-- Scores avec design sophistiqué -->
                    <HBox spacing="15" alignment="CENTER" style="-fx-padding: 10 0 10 0;">
                        <!-- Positif -->
                        <VBox spacing="6" alignment="CENTER" prefWidth="120"
                              style="-fx-background-color: #f0fdf4; -fx-background-radius: 10;
                                     -fx-padding: 12; -fx-border-color: #28a745; -fx-border-width: 2;
                                     -fx-border-radius: 10;">
                            <Label text="😊" style="-fx-font-size: 28px;"/>
                            <Label fx:id="labelScorePositif" text="0%"
                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #28a745;"/>
                            <Label text="Positif"
                                   style="-fx-font-size: 11px; -fx-text-fill: #28a745; -fx-font-weight: bold;"/>
                        </VBox>
                        
                        <!-- Neutre -->
                        <VBox spacing="6" alignment="CENTER" prefWidth="120"
                              style="-fx-background-color: #fffbeb; -fx-background-radius: 10;
                                     -fx-padding: 12; -fx-border-color: #f0a500; -fx-border-width: 2;
                                     -fx-border-radius: 10;">
                            <Label text="😐" style="-fx-font-size: 28px;"/>
                            <Label fx:id="labelScoreNeutre" text="0%"
                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #f0a500;"/>
                            <Label text="Neutre"
                                   style="-fx-font-size: 11px; -fx-text-fill: #f0a500; -fx-font-weight: bold;"/>
                        </VBox>
                        
                        <!-- Négatif -->
                        <VBox spacing="6" alignment="CENTER" prefWidth="120"
                              style="-fx-background-color: #fef2f2; -fx-background-radius: 10;
                                     -fx-padding: 12; -fx-border-color: #d52e28; -fx-border-width: 2;
                                     -fx-border-radius: 10;">
                            <Label text="😞" style="-fx-font-size: 28px;"/>
                            <Label fx:id="labelScoreNegatif" text="0%"
                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #d52e28;"/>
                            <Label text="Négatif"
                                   style="-fx-font-size: 11px; -fx-text-fill: #d52e28; -fx-font-weight: bold;"/>
                        </VBox>
                    </HBox>
                    
                    <!-- Séparateur -->
                    <HBox style="-fx-background-color: #e0e0e0; -fx-pref-height: 1;"/>
                    
                    <!-- Recommandation avec badge -->
                    <HBox style="-fx-background-color: #e8f4fd; -fx-padding: 12;
                                 -fx-background-radius: 8; -fx-border-color: #0078d4;
                                 -fx-border-width: 0 0 0 4; -fx-border-radius: 8;"
                          spacing="10" alignment="TOP_LEFT">
                        <Label text="💡" style="-fx-font-size: 18px;"/>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Recommandation Stratégique"
                                   style="-fx-font-weight: bold; -fx-text-fill: #0078d4; -fx-font-size: 12px;"/>
                            <Label fx:id="labelRecommandation" text="Analyse en cours..."
                                   wrapText="true"
                                   style="-fx-text-fill: #0078d4; -fx-font-size: 12px; -fx-font-weight: bold;"
                                   maxWidth="500"/>
                        </VBox>
                    </HBox>
                    
                    <!-- Explication détaillée -->
                    <VBox style="-fx-background-color: #f8f9fa; -fx-padding: 14;
                                 -fx-background-radius: 8; -fx-border-color: #dee2e6;
                                 -fx-border-width: 1; -fx-border-radius: 8;"
                          spacing="6">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="📋" style="-fx-font-size: 16px;"/>
                            <Label text="Guide de Réponse Personnalisée"
                                   style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 12px;"/>
                        </HBox>
                        <Label fx:id="labelExplication" 
                               text="L'intelligence artificielle analyse le ton, les émotions et le contexte du message pour vous proposer la meilleure approche de réponse..."
                               wrapText="true"
                               style="-fx-text-fill: #495057; -fx-font-size: 11px; -fx-line-spacing: 2px;"
                               maxWidth="540"/>
                    </VBox>
                    
                </VBox>
            </VBox>

            <!-- BOUTON GEMINI IA -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),5,0,0,2);
                         -fx-padding: 0;">
                <HBox style="-fx-background-color: #7c3aed; -fx-padding: 10 15 10 15;
                             -fx-background-radius: 8 8 0 0;" alignment="CENTER_LEFT" spacing="8">
                    <Label text="Gemini IA — Suggestion Automatique"
                           style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 12px;"/>
                </HBox>
                <VBox spacing="10" style="-fx-padding: 14;">
                    <Label text="Laissez Gemini IA analyser ce feedback et generer une reponse professionnelle automatiquement."
                           wrapText="true"
                           style="-fx-text-fill: #555; -fx-font-size: 11px;"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Button fx:id="btnGemini"
                                text="Suggerer avec Gemini IA"
                                onAction="#suggererAvecGemini"
                                style="-fx-background-color: #7c3aed; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 6;
                                       -fx-padding: 9 18 9 18; -fx-cursor: hand; -fx-font-size: 12px;"/>
                        <Label fx:id="labelGeminiStatus" text=""
                               style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- FORMULAIRE -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),5,0,0,2);
                         -fx-padding: 0;">
                <HBox style="-fx-background-color: #28a745; -fx-padding: 10 15 10 15;
                             -fx-background-radius: 8 8 0 0;" alignment="CENTER_LEFT" spacing="8">
                    <Label text="Formulaire de Traitement"
                           style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 12px;"/>
                </HBox>

                <VBox spacing="14" style="-fx-padding: 16;">

                    <!-- Type -->
                    <VBox spacing="5">
                        <Label text="Type de traitement *"
                               style="-fx-font-weight: bold; -fx-text-fill: #333; -fx-font-size: 12px;"/>
                        <ComboBox fx:id="comboType"
                                  promptText="-- Selectionner un type --"
                                  maxWidth="Infinity"
                                  style="-fx-background-radius: 6; -fx-border-color: #ddd;
                                         -fx-border-radius: 6;"/>
                    </VBox>

                    <!-- Réponse -->
                    <VBox spacing="5">
                        <Label text="Reponse a l'utilisateur *"
                               style="-fx-font-weight: bold; -fx-text-fill: #333; -fx-font-size: 12px;"/>
                        <TextArea fx:id="textDescription"
                                  promptText="Ecrivez votre reponse ou utilisez Gemini IA..."
                                  prefHeight="120"
                                  wrapText="true"
                                  style="-fx-background-radius: 6; -fx-border-color: #ddd;
                                         -fx-border-radius: 6;"/>
                        <Label text="Minimum 10 caracteres, maximum 1000."
                               style="-fx-text-fill: #aaa; -fx-font-size: 10px;"/>
                    </VBox>

                    <!-- Avertissement -->
                    <HBox style="-fx-background-color: #fff8e1; -fx-padding: 10;
                                 -fx-background-radius: 6; -fx-border-color: #f0a500;
                                 -fx-border-width: 0 0 0 3;"
                          spacing="8" alignment="CENTER_LEFT">
                        <Label text="Une fois enregistre, le statut passera a Traite."
                               wrapText="true"
                               style="-fx-text-fill: #856404; -fx-font-size: 11px;"
                               maxWidth="480"/>
                    </HBox>

                    <!-- Erreur -->
                    <Label fx:id="labelErreur" text=""
                           style="-fx-text-fill: #d52e28; -fx-font-size: 12px;"/>

                </VBox>
            </VBox>

        </VBox>
    </ScrollPane>

    <!-- BOUTONS BAS -->
    <HBox spacing="10" alignment="CENTER_RIGHT"
          style="-fx-padding: 14 20 14 20; -fx-background-color: white;
                 -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">
        <Button text="Annuler" onAction="#annuler"
                style="-fx-background-color: transparent; -fx-text-fill: #555;
                       -fx-border-color: #ccc; -fx-border-radius: 6;
                       -fx-background-radius: 6; -fx-padding: 9 20 9 20;
                       -fx-cursor: hand; -fx-font-size: 12px;"/>
        <Button text="Enregistrer le traitement" onAction="#confirmer"
                style="-fx-background-color: #28a745; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 6;
                       -fx-padding: 9 20 9 20; -fx-cursor: hand; -fx-font-size: 12px;"/>
    </HBox>

</VBox>