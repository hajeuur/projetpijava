<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connection3a36.controllers.UtilisateurListController"
      spacing="15">

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="👥 Gestion des Utilisateurs" styleClass="section-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Nouvel Utilisateur" onAction="#handleAdd" styleClass="btn-success"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <ComboBox fx:id="roleFilter" promptText="Tous les rôles" prefWidth="200" onAction="#handleFilter"/>
        <Button text="Réinitialiser" onAction="#handleReset" styleClass="btn-secondary"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblTotal" text="Total: 0" style="-fx-font-weight: bold;"/>
    </HBox>

    <TableView fx:id="tableUtilisateurs" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colNom" text="Nom complet" prefWidth="200"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="250"/>
            <TableColumn fx:id="colRole" text="Rôle" prefWidth="150"/>
            <TableColumn fx:id="colStatus" text="Statut" prefWidth="100"/>
            <TableColumn fx:id="colActions" text="Actions" prefWidth="180"/>
        </columns>
    </TableView>

</VBox>
