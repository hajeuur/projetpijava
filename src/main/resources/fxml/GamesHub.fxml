<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connection3a36.controllers.GamesHubController"
      spacing="0" style="-fx-background-color: #f0f4f8;">

    <HBox style="-fx-background-color: linear-gradient(to right, #1a237e, #283593); -fx-padding: 14 25;"
          alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="🧩 Hub d’Intervention Pédagogique"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Interventions, diagnostic, accessibilité et suivi d’impact pour enseignants et administration."
                   style="-fx-text-fill: rgba(255,255,255,0.78); -fx-font-size: 13px;"/>
        </VBox>
        <Button fx:id="btnDyslexia" text="📖 Mode Dyslexie" onAction="#toggleDyslexiaMode"
                style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-padding: 8 18; -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>

    <HBox spacing="6" style="-fx-background-color: white; -fx-padding: 8 20; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
        <Button fx:id="tabInterventions" text="Interventions" onAction="#showInterventions"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand;"/>
        <Button fx:id="tabDiagnostic" text="Diagnostic" onAction="#showDiagnostic"
                style="-fx-background-color: #e2e8f0; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand;"/>
        <Button fx:id="tabAccessibilite" text="Accessibilité" onAction="#showAccessibilite"
                style="-fx-background-color: #e2e8f0; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand;"/>
        <Button fx:id="tabImpact" text="Suivi d’impact" onAction="#showImpact"
                style="-fx-background-color: #e2e8f0; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand;"/>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS" style="-fx-padding: 20;">

        <VBox fx:id="paneInterventions" spacing="14" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 24;">
            <Label text="Bloc A — Interventions enseignant (priorité haute)" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #102c59;"/>
            <HBox spacing="10">
                <VBox spacing="6">
                    <Label text="Niveau"/>
                    <ComboBox fx:id="cbNiveau" prefWidth="160"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Profil"/>
                    <ComboBox fx:id="cbProfil" prefWidth="220"/>
                </VBox>
                <Button text="Générer pack 15 min" onAction="#generateInterventionPack"
                        style="-fx-background-color:#2563eb;-fx-text-fill:white;-fx-padding:8 16;-fx-background-radius:10;-fx-cursor:hand;"/>
            </HBox>
            <HBox spacing="10" VBox.vgrow="ALWAYS">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Générateur de micro-activités (15 min)"/>
                    <TextArea fx:id="taIntervention" prefRowCount="9" wrapText="true"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Banque de remédiation"/>
                    <TextArea fx:id="taRemediation" prefRowCount="9" wrapText="true"/>
                </VBox>
            </HBox>
            <VBox spacing="6">
                <Label text="Script de séance prêt à l’emploi (objectif, déroulé, évaluation flash)"/>
                <TextArea fx:id="taScriptSeance" prefRowCount="7" wrapText="true"/>
            </VBox>
        </VBox>

        <VBox fx:id="paneDiagnostic" spacing="14" visible="false" managed="false"
              style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 24;">
            <Label text="Bloc A — Quiz diagnostic rapide (5 questions)" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #102c59;"/>
            <Label text="Échelle: Jamais / Rarement / Parfois / Souvent"/>
            <GridPane hgap="12" vgap="10">
                <columnConstraints>
                    <ColumnConstraints percentWidth="70"/>
                    <ColumnConstraints percentWidth="30"/>
                </columnConstraints>
                <Label text="1) L’étudiant perd rapidement sa concentration." GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cbQ1" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Label text="2) Les absences impactent les acquis de base." GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cbQ2" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                <Label text="3) Les consignes écrites sont difficiles à suivre." GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cbQ3" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                <Label text="4) Le travail est irrégulier d’une séance à l’autre." GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cbQ4" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                <Label text="5) Le feedback enseignant est rarement appliqué." GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cbQ5" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
            </GridPane>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Évaluer le diagnostic" onAction="#runDiagnostic"
                        style="-fx-background-color:#d97706;-fx-text-fill:white;-fx-padding:8 16;-fx-background-radius:10;-fx-cursor:hand;"/>
                <Label fx:id="lblDiagScore" text="Score diagnostic: -- / 15" style="-fx-font-weight:bold;"/>
            </HBox>
            <TextArea fx:id="taDiagRecommendation" prefRowCount="9" wrapText="true"/>
        </VBox>

        <VBox fx:id="paneAccessibilite" spacing="14" visible="false" managed="false"
              style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 24;">
            <Label text="Bloc C — Accessibilité (outils à valeur pédagogique)" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #102c59;"/>
            <HBox spacing="14" VBox.vgrow="ALWAYS">
                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Lecture adaptée"/>
                    <HBox spacing="8">
                        <Button text="Crème" onAction="#setBgCream"/>
                        <Button text="Vert pâle" onAction="#setBgGreen"/>
                        <Button text="Bleu pâle" onAction="#setBgBlue"/>
                        <Button text="Normal" onAction="#setBgNormal"/>
                    </HBox>
                    <Label text="Taille de police"/>
                    <Slider fx:id="fontSizeSlider" min="12" max="24" value="15" onMouseReleased="#adjustFontSize"/>
                    <Label text="Espacement des lettres"/>
                    <Slider fx:id="letterSpacingSlider" min="0" max="8" value="2" onMouseReleased="#adjustLetterSpacing"/>
                    <VBox fx:id="previewBox" spacing="6" style="-fx-background-color:#fdf6e3;-fx-padding:16;-fx-background-radius:10;">
                        <Label fx:id="previewText1" text="Prévisualisation de lecture adaptée"/>
                        <Label fx:id="previewText2" text="Consignes plus lisibles pour les profils dyslexiques."/>
                        <Label fx:id="previewText3" text="Support court, clair, structuré."/>
                    </VBox>
                </VBox>
                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Lecture audio lettre/syllabe"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <ComboBox fx:id="cbAudioSymbol" prefWidth="150"/>
                        <Button text="Lire" onAction="#playSelectedAudio"
                                style="-fx-background-color:#7c3aed;-fx-text-fill:white;-fx-padding:8 14;-fx-background-radius:10;-fx-cursor:hand;"/>
                    </HBox>
                    <Label fx:id="lblSoundFeedback" text="Prêt pour lecture audio."/>
                    <Separator/>
                    <Label text="Focus timer de séance (Pomodoro pédagogique)"/>
                    <Label fx:id="lblPomodoroMode" text="MODE TRAVAIL" style="-fx-font-weight:bold;"/>
                    <StackPane>
                        <Circle radius="70" fill="transparent" stroke="#dc2626" strokeWidth="6"/>
                        <Label fx:id="lblPomodoroTime" text="25:00" style="-fx-font-size:34px;-fx-font-weight:bold;"/>
                    </StackPane>
                    <HBox spacing="8">
                        <Button text="Start/Pause" onAction="#togglePomodoro"/>
                        <Button text="Reset" onAction="#resetPomodoro"/>
                    </HBox>
                    <Label fx:id="lblPomodoroSessions" text="Sessions finalisées: 0"/>
                    <Label fx:id="lblPomodoroMotivation" text="&quot;Progression > perfection.&quot;" wrapText="true"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox fx:id="paneImpact" spacing="14" visible="false" managed="false"
              style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 24;">
            <Label text="Bloc B — Centre admin: alertes, décisions hebdo, impact des plans" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #102c59;"/>
            <HBox spacing="12">
                <VBox styleClass="stat-card-red" spacing="4" prefWidth="180">
                    <Label text="Élèves à risque"/>
                    <Label fx:id="lblAtRiskCount" text="0" style="-fx-font-size:24px;-fx-font-weight:bold;"/>
                </VBox>
                <VBox styleClass="stat-card-orange" spacing="4" prefWidth="180">
                    <Label text="Feedback manquant"/>
                    <Label fx:id="lblMissingFeedback" text="0" style="-fx-font-size:24px;-fx-font-weight:bold;"/>
                </VBox>
                <VBox styleClass="stat-card-blue" spacing="4" prefWidth="180">
                    <Label text="Plans en retard"/>
                    <Label fx:id="lblLatePlans" text="0" style="-fx-font-size:24px;-fx-font-weight:bold;"/>
                </VBox>
                <VBox styleClass="stat-card-steel" spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Résumé impact"/>
                    <Label fx:id="lblImpactSummary" text="--"/>
                </VBox>
            </HBox>
            <HBox spacing="10">
                <Button text="Actualiser les alertes" onAction="#refreshImpact"/>
                <Button text="Assistant: top 3 actions semaine" onAction="#generateWeeklyActions"/>
            </HBox>
            <HBox spacing="10" VBox.vgrow="ALWAYS">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Assistant de décision"/>
                    <TextArea fx:id="taWeeklyActions" prefRowCount="10" wrapText="true"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Suivi d’impact avant/après"/>
                    <TextArea fx:id="taImpactDetail" prefRowCount="10" wrapText="true"/>
                </VBox>
            </HBox>
        </VBox>
    </StackPane>
</VBox>
