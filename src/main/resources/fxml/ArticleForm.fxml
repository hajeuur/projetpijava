<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connection3a36.controllers.ArticleFormController"
      spacing="18" styleClass="form-card">
    <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>

    <!-- Titre -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="📝" style="-fx-font-size: 24px;"/>
        <Label fx:id="formTitle" text="Nouvel Article" styleClass="section-title"/>
    </HBox>
    <Separator/>

    <!-- Titre article -->
    <VBox spacing="5">
        <Label text="Titre *" styleClass="form-label"/>
        <TextField fx:id="tfTitre"
                   promptText="Titre de l'article (min 5 car., max 255)"
                   maxWidth="Infinity"/>
        <Label fx:id="errTitre" styleClass="error-label" text=""
               managed="false" visible="false"/>
    </VBox>

    <!-- Contenu -->
    <VBox spacing="5" VBox.vgrow="ALWAYS">
        <Label text="Contenu *" styleClass="form-label"/>
        <TextArea fx:id="taContenu"
                  promptText="Contenu de l'article (min 20 car.)"
                  prefRowCount="8" wrapText="true" VBox.vgrow="ALWAYS"/>
        <Label fx:id="errContenu" styleClass="error-label" text=""
               managed="false" visible="false"/>
    </VBox>

    <!-- Catégorie &amp; Publication -->
    <HBox spacing="20" alignment="CENTER_LEFT">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Catégorie *" styleClass="form-label"/>
            <ComboBox fx:id="cbCategorie" maxWidth="Infinity"
                      promptText="Choisir une catégorie"/>
            <Label fx:id="errCategorie" styleClass="error-label" text=""
                   managed="false" visible="false"/>
        </VBox>
        <VBox spacing="5" alignment="CENTER_LEFT">
            <Label text="Publication" styleClass="form-label"/>
            <CheckBox fx:id="chkPublished" text="Publier cet article"/>
        </VBox>
    </HBox>

    <!-- Boutons -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button text="💾 Sauvegarder" onAction="#handleSave" styleClass="btn-success"/>
    </HBox>

</VBox>
