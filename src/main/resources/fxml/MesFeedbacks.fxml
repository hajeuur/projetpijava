<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mentorai.controllers.MesFeedbacksController"
      spacing="0"
      style="-fx-background-color: #f0f4f8;"
      prefWidth="1200" prefHeight="800">

    <!-- ===== BANNER HEADER ===== -->
    <VBox alignment="CENTER_LEFT" style="-fx-background-color: #102c59; -fx-padding: 30 50;">
        <HBox alignment="CENTER_LEFT" spacing="20">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Mes Feedbacks" 
                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Retrouvez ici tous les feedbacks que vous avez envoyés ainsi que leur statut." 
                       style="-fx-font-size: 15px; -fx-text-fill: #9dbbce;"/>
            </VBox>
            <Button text="+ Nouveau Feedback" onAction="#nouveauFeedback"
                    style="-fx-background-color: #d52e28; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 50; -fx-padding: 12 25; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <!-- ===== SEARCH AND FILTER BAR ===== -->
    <HBox spacing="15" alignment="CENTER_LEFT" 
          style="-fx-padding: 20 50; -fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
        <TextField fx:id="champRecherche" 
                   promptText="🔍 Rechercher par message (ex: problème...)"
                   prefWidth="400"
                   style="-fx-background-radius: 8; -fx-border-color: #dcdde1; -fx-border-radius: 8; -fx-padding: 10;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Trier par :" style="-fx-font-weight: bold; -fx-text-fill: #102c59;"/>
        <ComboBox fx:id="comboTri" prefWidth="180"
                  style="-fx-background-radius: 8; -fx-border-color: #dcdde1; -fx-border-radius: 8; -fx-padding: 5;"/>
    </HBox>

    <!-- ===== CONTENU ===== -->
    <VBox VBox.vgrow="ALWAYS" spacing="15" style="-fx-padding: 20 50 20 50;">

        <!-- ===== TABLEAU ===== -->
        <VBox VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 8;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),5,0,0,2);">

            <TableView fx:id="tableFeedbacks" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent;">
                <columns>
                    <TableColumn fx:id="colId"       text="#"             prefWidth="50"/>
                    <TableColumn fx:id="colPriorite" text="Priorité"      prefWidth="100"/>
                    <TableColumn fx:id="colType"     text="Type"          prefWidth="110"/>
                    <TableColumn fx:id="colDate"     text="Date"          prefWidth="100"/>
                    <TableColumn fx:id="colNote"     text="Note"          prefWidth="80"/>
                    <TableColumn fx:id="colMessage"  text="Message"       prefWidth="200"/>
                    <TableColumn fx:id="colEtat"     text="État"          prefWidth="110"/>
                    <TableColumn fx:id="colReponse"  text="Réponse admin" prefWidth="160"/>
                    <TableColumn fx:id="colActions"  text="Actions"       prefWidth="180"/>
                </columns>
            </TableView>
        </VBox>

        <!-- Total -->
        <Label fx:id="labelTotal"
               text="ⓘ  Total : 0 feedback(s)"
               style="-fx-text-fill: #888; -fx-font-size: 12px;"/>
    </VBox>
</VBox>