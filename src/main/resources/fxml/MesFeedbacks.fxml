<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mentorai.controllers.MesFeedbacksController"
      spacing="0"
      style="-fx-background-color: #f5f7fa;"
      prefWidth="950" prefHeight="650">

    <!-- ===== HEADER ===== -->
    <HBox style="-fx-background-color: #102c59; -fx-padding: 15 25 15 25;"
          alignment="CENTER_LEFT" spacing="15">
        <Label text="MentorAI"
               style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Label text="| Mes Feedbacks"
               style="-fx-text-fill: #9dbbce; -fx-font-size: 14px;"/>
        <HBox HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT">
            <Button text="➕  Nouveau feedback"
                    onAction="#nouveauFeedback"
                    style="-fx-background-color: #d52e28; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 20;
                           -fx-padding: 8 18 8 18; -fx-cursor: hand;"/>
        </HBox>
    </HBox>

    <!-- ===== CONTENU ===== -->
    <VBox VBox.vgrow="ALWAYS" spacing="15" style="-fx-padding: 20;">

        <!-- Titre -->
        <VBox spacing="3">
            <Label text="Historique de vos feedbacks"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #102c59;"/>
            <Label text="Retrouvez ici tous les feedbacks que vous avez envoyés ainsi que leur statut."
                   style="-fx-text-fill: #888; -fx-font-size: 12px;"/>
        </VBox>

        <!-- ===== BARRE RECHERCHE + TRI ===== -->
        <HBox style="-fx-background-color: white; -fx-padding: 12 15 12 15;
                     -fx-background-radius: 8;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),5,0,0,2);"
              spacing="12" alignment="CENTER_LEFT">

            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="🔍  Rechercher par message"
                       style="-fx-text-fill: #102c59; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <TextField fx:id="champRecherche"
                           promptText="Tapez un mot-clé (ex: chat bot, problème...)"
                           style="-fx-background-radius: 6; -fx-border-color: #ddd;
                                  -fx-border-radius: 6; -fx-padding: 7;"/>
            </VBox>

            <VBox spacing="3">
                <Label text="↕  Trier par date"
                       style="-fx-text-fill: #102c59; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <ComboBox fx:id="comboTri"
                          prefWidth="180"
                          style="-fx-background-radius: 6;"/>
            </VBox>

            <VBox spacing="3">
                <Label text="" style="-fx-font-size: 11px;"/>
                <Button text="Filtrer"
                        onAction="#filtrer"
                        style="-fx-background-color: #9dbbce; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 6;
                               -fx-padding: 7 16 7 16; -fx-cursor: hand;"/>
            </VBox>
        </HBox>

        <!-- ===== TABLEAU ===== -->
        <VBox VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 8;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),5,0,0,2);">

            <TableView fx:id="tableFeedbacks" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent;">
                <columns>
                    <TableColumn fx:id="colId"      text="#"             prefWidth="55"/>
                    <TableColumn fx:id="colType"    text="Type"          prefWidth="120"/>
                    <TableColumn fx:id="colDate"    text="Date"          prefWidth="110"/>
                    <TableColumn fx:id="colNote"    text="Note"          prefWidth="100"/>
                    <TableColumn fx:id="colMessage" text="Message"       prefWidth="220"/>
                    <TableColumn fx:id="colEtat"    text="État"          prefWidth="110"/>
                    <TableColumn fx:id="colReponse" text="Réponse admin" prefWidth="170"/>
                    <TableColumn fx:id="colActions" text="Actions"       prefWidth="180"/>
                </columns>
            </TableView>
        </VBox>

        <!-- Total -->
        <Label fx:id="labelTotal"
               text="ⓘ  Total : 0 feedback(s)"
               style="-fx-text-fill: #888; -fx-font-size: 12px;"/>

    </VBox>
</VBox>