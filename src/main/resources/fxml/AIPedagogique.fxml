<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connection3a36.controllers.AIPedagogiqueController"
      spacing="16">

    <!-- ===== PAGE HEADER ===== -->
    <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="🤖 Assistant IA Pédagogique" styleClass="section-title"/>
            <Label text="Analysez les performances, détectez les risques, créez des plans et des articles"
                   styleClass="section-subtitle"/>
        </VBox>
        <Label fx:id="lblStatus" text="" style="-fx-text-fill: #7a8fa5; -fx-font-size: 12px;"/>
        <Button text="🕐 Historique"   onAction="#handleShowHistory"  styleClass="btn-secondary"/>
        <Button text="🗑️ Effacer"      onAction="#handleClear"        styleClass="btn-secondary"/>
    </HBox>

    <!-- ===== SUGGESTIONS RAPIDES ===== -->
    <VBox styleClass="card" spacing="10">
        <Label text="💡 Questions suggérées"
               style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #102c59;"/>
        <FlowPane hgap="8" vgap="8">
            <Button text="🔍 Aide Notion (Wiki)" onAction="#handleWikipediaSearch" styleClass="chip-primary" style="-fx-background-color: #3b82f6; -fx-text-fill: white;"/>
            <Button text="📊 Analyser les performances"    onAction="#handleSuggestion1" styleClass="chip-primary"/>
            <Button text="⚠️ Détecter les risques"         onAction="#handleSuggestion2" styleClass="chip-warning"/>
            <Button text="📋 Plan d'action recommandé"     onAction="#handleSuggestion3" styleClass="chip-success"/>
            <Button text="📚 Voir articles recommandés"    onAction="#handleRecommendArticles" styleClass="chip-steel"/>
        </FlowPane>
    </VBox>

    <!-- ===== ZONE DE CHAT ===== -->
    <ScrollPane fx:id="chatScroll" VBox.vgrow="ALWAYS" fitToWidth="true"
                styleClass="chat-container" style="-fx-min-height: 280px;">
        <VBox fx:id="chatBox" spacing="12">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
        </VBox>
    </ScrollPane>

    <!-- ===== ACTIONS IA ===== -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Button text="📋 → Plan d'Action IA" onAction="#handleCreatePlan"
                styleClass="chip-success" style="-fx-font-size: 12px;"/>
        <Button text="✍️ Générer un Article" onAction="#handleGenerateArticle"
                styleClass="chip-steel" style="-fx-font-size: 12px;"/>
    </HBox>

            <!-- Barre d'envoi -->
            <HBox styleClass="chat-input-area" spacing="10" alignment="CENTER_LEFT">
                <Button text="❓ WIKI" onAction="#handleWikipediaSearch"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;"/>
                <TextField fx:id="inputField"
                   promptText="✏️  Posez une question pédagogique..."
                   HBox.hgrow="ALWAYS" styleClass="search-bar" onAction="#handleSend"
                   style="-fx-padding: 11 15; -fx-border-width: 0; -fx-background-radius: 10;"/>
        <Button fx:id="btnRecord" text="🎤" onAction="#handleRecord" 
                styleClass="btn-secondary" style="-fx-padding: 10 15; -fx-cursor: hand;"/>
        <Button fx:id="btnSend" text="📤 Envoyer" onAction="#handleSend"
                styleClass="btn-primary" style="-fx-padding: 10 22;"/>
    </HBox>

</VBox>
