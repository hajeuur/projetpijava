<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connection3a36.controllers.AIPedagogiqueController"
      spacing="15">

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="🤖 Assistant IA Pédagogique" styleClass="section-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🗑️ Effacer la conversation" onAction="#handleClear" styleClass="btn-secondary"/>
    </HBox>

    <Label text="Posez vos questions sur la pédagogie, les étudiants, les performances..." styleClass="section-subtitle"/>

    <!-- Suggestions de prompts -->
    <HBox spacing="8">
        <Button text="📊 Analyser les performances" onAction="#handleSuggestion1" styleClass="btn-primary"
                style="-fx-font-size: 11px; -fx-padding: 5 10;"/>
        <Button text="⚠️ Détecter les risques" onAction="#handleSuggestion2" styleClass="btn-warning"
                style="-fx-font-size: 11px; -fx-padding: 5 10;"/>
        <Button text="📋 Recommander un plan" onAction="#handleSuggestion3" styleClass="btn-success"
                style="-fx-font-size: 11px; -fx-padding: 5 10;"/>
    </HBox>

    <!-- Zone de chat -->
    <ScrollPane fx:id="chatScroll" VBox.vgrow="ALWAYS" fitToWidth="true"
                styleClass="chat-container" style="-fx-padding: 10;">
        <VBox fx:id="chatBox" spacing="10">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
        </VBox>
    </ScrollPane>

    <!-- Barre d'envoi -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="inputField" promptText="Écrivez votre message..."
                   HBox.hgrow="ALWAYS" styleClass="search-bar" onAction="#handleSend"/>
        <Button fx:id="btnSend" text="📤 Envoyer" onAction="#handleSend" styleClass="btn-primary"/>
    </HBox>

    <Label fx:id="lblStatus" text="" style="-fx-text-fill: #95a5a6; -fx-font-size: 12px;"/>

</VBox>
