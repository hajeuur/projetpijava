<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mentorai.controllers.AdminFeedbackController"
      spacing="0"
      style="-fx-background-color: #f5f5f5;"
      prefWidth="1100" prefHeight="750">

    <!-- HEADER -->
    <HBox style="-fx-background-color: #102c59; -fx-padding: 15 20 15 20;"
          alignment="CENTER_LEFT" spacing="20">
        <Label text="MentorAI"
               style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
        <Label text="| Gestion des Feedbacks"
               style="-fx-text-fill: #9dbbce; -fx-font-size: 16px;"/>
        <HBox HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT" spacing="10">
            <Label fx:id="labelEnAttente" text="0 en attente"
                   style="-fx-background-color: #f0a500; -fx-text-fill: white;
                          -fx-padding: 5 12 5 12; -fx-background-radius: 20;
                          -fx-font-weight: bold;"/>
            <Label fx:id="labelTraites" text="0 traités"
                   style="-fx-background-color: #28a745; -fx-text-fill: white;
                          -fx-padding: 5 12 5 12; -fx-background-radius: 20;
                          -fx-font-weight: bold;"/>
        </HBox>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox spacing="20" style="-fx-padding: 20;">

            <!-- RECHERCHE + TRI -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),5,0,0,2);
                         -fx-padding: 0;">
                <HBox style="-fx-background-color: #102c59; -fx-padding: 10 15 10 15;
                             -fx-background-radius: 8 8 0 0;" alignment="CENTER_LEFT">
                    <Label text="Recherche et Filtres"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                </HBox>
                <HBox spacing="12" style="-fx-padding: 12 15 12 15;" alignment="CENTER_LEFT">
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Rechercher par message"
                               style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
                        <TextField fx:id="champRecherche"
                                   promptText="Mot-clé dans le message..."
                                   style="-fx-background-radius: 6; -fx-border-color: #ddd;
                                          -fx-border-radius: 6; -fx-padding: 7;"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="Filtrer par type"
                               style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
                        <ComboBox fx:id="comboFiltreType" prefWidth="160"
                                  style="-fx-background-radius: 6;"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="Trier par"
                               style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
                        <ComboBox fx:id="comboTri" prefWidth="170"
                                  style="-fx-background-radius: 6;"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="" style="-fx-font-size: 11px;"/>
                        <Button text="Rechercher" onAction="#filtrer"
                                style="-fx-background-color: #102c59; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 6;
                                       -fx-padding: 7 16 7 16; -fx-cursor: hand;"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="" style="-fx-font-size: 11px;"/>
                        <Button text="Reinitialiser" onAction="#reinitialiser"
                                style="-fx-background-color: #e0e0e0; -fx-text-fill: #333;
                                       -fx-background-radius: 6;
                                       -fx-padding: 7 16 7 16; -fx-cursor: hand;"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="" style="-fx-font-size: 11px;"/>
                        <Button text="Export PDF" onAction="#exporterPDF"
                                style="-fx-background-color: #d52e28; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 6;
                                       -fx-padding: 7 16 7 16; -fx-cursor: hand;"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="" style="-fx-font-size: 11px;"/>
                        <Button text="Export Excel" onAction="#exporterExcel"
                                style="-fx-background-color: #28a745; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 6;
                                       -fx-padding: 7 16 7 16; -fx-cursor: hand;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ✅ CALENDRIER DYNAMIQUE -->
            <VBox fx:id="calendrierContainer"
                  style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),5,0,0,2);
                         -fx-padding: 0;">

                <!-- Header calendrier -->
                <HBox style="-fx-background-color: #102c59; -fx-padding: 10 15 10 15;
                             -fx-background-radius: 8 8 0 0;" alignment="CENTER_LEFT" spacing="10">
                    <Label text="Calendrier des Feedbacks"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                    <HBox HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT" spacing="8">
                        <!-- Switch vue -->
                        <Button fx:id="btnVueMois" text="Mois" onAction="#switchVueMois"
                                style="-fx-background-color: white; -fx-text-fill: #102c59;
                                       -fx-font-weight: bold; -fx-background-radius: 5;
                                       -fx-padding: 4 12 4 12; -fx-cursor: hand; -fx-font-size: 11px;"/>
                        <Button fx:id="btnVueSemaine" text="Semaine" onAction="#switchVueSemaine"
                                style="-fx-background-color: transparent; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 5;
                                       -fx-border-color: white; -fx-border-radius: 5;
                                       -fx-padding: 4 12 4 12; -fx-cursor: hand; -fx-font-size: 11px;"/>
                    </HBox>
                </HBox>

                <!-- Navigation mois/semaine -->
                <HBox alignment="CENTER" spacing="20"
                      style="-fx-padding: 10 15 10 15; -fx-border-color: #eee; -fx-border-width: 0 0 1 0;">
                    <Button text="&lt;" onAction="#moisPrecedent"
                            style="-fx-background-color: #102c59; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 20;
                                   -fx-padding: 5 14 5 14; -fx-cursor: hand; -fx-font-size: 14px;"/>
                    <Label fx:id="labelMoisAnnee" text="Avril 2026"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;
                                  -fx-text-fill: #102c59; -fx-min-width: 160px;"
                           alignment="CENTER"/>
                    <Button text="&gt;" onAction="#moisSuivant"
                            style="-fx-background-color: #102c59; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 20;
                                   -fx-padding: 5 14 5 14; -fx-cursor: hand; -fx-font-size: 14px;"/>
                    <!-- Légende -->
                    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 0 0 0 20;">
                        <Label text="  " style="-fx-background-color: #d52e28;
                               -fx-background-radius: 3; -fx-padding: 4 8 4 8;"/>
                        <Label text="Probleme" style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
                        <Label text="  " style="-fx-background-color: #28a745;
                               -fx-background-radius: 3; -fx-padding: 4 8 4 8;"/>
                        <Label text="Satisfaction" style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
                        <Label text="  " style="-fx-background-color: #f0a500;
                               -fx-background-radius: 3; -fx-padding: 4 8 4 8;"/>
                        <Label text="Suggestion" style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
                        <Label text="  " style="-fx-background-color: #9dbbce;
                               -fx-background-radius: 3; -fx-padding: 4 8 4 8;"/>
                        <Label text="Multiple" style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
                    </HBox>
                </HBox>

                <!-- Jours de la semaine -->
                <GridPane fx:id="headerJours" style="-fx-padding: 5 10 0 10;">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                    </columnConstraints>
                </GridPane>

                <!-- Grille du calendrier -->
                <GridPane fx:id="grilleCalendrier"
                          style="-fx-padding: 5 10 10 10;" hgap="4" vgap="4">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                        <ColumnConstraints percentWidth="14.28"/>
                    </columnConstraints>
                </GridPane>

            </VBox>

            <!-- SECTION NON TRAITÉS -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.1),5,0,0,2);">
                <HBox style="-fx-background-color: #fff3cd; -fx-padding: 12 15 12 15;
                             -fx-background-radius: 8 8 0 0;" alignment="CENTER_LEFT">
                    <Label text="Feedbacks en attente de traitement"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;
                                  -fx-text-fill: #856404;"/>
                </HBox>
                <TableView fx:id="tableNonTraites"
                           style="-fx-background-color: transparent;"
                           prefHeight="250">
                    <columns>
                        <TableColumn fx:id="colIdNT"       text="#"        prefWidth="50"/>
                        <TableColumn fx:id="colPrioriteNT" text="Priorite" prefWidth="90"/>
                        <TableColumn fx:id="colTypeNT"     text="Type"     prefWidth="100"/>
                        <TableColumn fx:id="colDateNT"     text="Date"     prefWidth="100"/>
                        <TableColumn fx:id="colNoteNT"     text="Note"     prefWidth="60"/>
                        <TableColumn fx:id="colMessageNT"  text="Message"  prefWidth="300"/>
                        <TableColumn fx:id="colActionNT"   text="Actions"  prefWidth="190"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- SECTION TRAITÉS -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.1),5,0,0,2);">
                <HBox style="-fx-background-color: #d4edda; -fx-padding: 12 15 12 15;
                             -fx-background-radius: 8 8 0 0;" alignment="CENTER_LEFT">
                    <Label text="Historique des feedbacks traites"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;
                                  -fx-text-fill: #155724;"/>
                </HBox>
                <TableView fx:id="tableTraites"
                           style="-fx-background-color: transparent;"
                           prefHeight="280">
                    <columns>
                        <TableColumn fx:id="colIdT"         text="#"          prefWidth="55"/>
                        <TableColumn fx:id="colTypeT"       text="Type"       prefWidth="100"/>
                        <TableColumn fx:id="colDateT"       text="Date"       prefWidth="100"/>
                        <TableColumn fx:id="colNoteT"       text="Note"       prefWidth="60"/>
                        <TableColumn fx:id="colMessageT"    text="Message"    prefWidth="200"/>
                        <TableColumn fx:id="colTraitementT" text="Traitement" prefWidth="130"/>
                        <TableColumn fx:id="colActionT"     text="Actions"    prefWidth="220"/>
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>