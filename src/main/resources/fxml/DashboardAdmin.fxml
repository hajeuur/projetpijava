<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connection3a36.controllers.DashboardAdminController"
            fitToWidth="true" style="-fx-background-color:transparent;-fx-border-color:transparent;">
<content>
<VBox spacing="16" style="-fx-padding: 0 0 20 0;">

    <!-- ===== PAGE HEADER ===== -->
    <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="Dashboard Admin" styleClass="section-title"/>
            <Label text="Vue d'ensemble stratégique de l'établissement"
                   styleClass="section-subtitle"/>
        </VBox>
        <Button text="Rafraîchir" onAction="#handleRefresh" styleClass="btn-secondary"/>
    </HBox>

    <!-- ===== CARTES STATISTIQUES ===== -->
    <HBox spacing="15">
        <VBox styleClass="stat-card-blue" alignment="CENTER" HBox.hgrow="ALWAYS" spacing="5">
            <Label fx:id="lblTotalPlans" text="0" styleClass="stat-number"/>
            <Label text="Plans d'Actions" styleClass="stat-label"/>
            <Label text="📋" style="-fx-font-size: 20px; -fx-opacity: 0.5;"/>
        </VBox>
        <VBox styleClass="stat-card-green" alignment="CENTER" HBox.hgrow="ALWAYS" spacing="5">
            <Label fx:id="lblTotalArticles" text="0" styleClass="stat-number"/>
            <Label text="Articles Publiés" styleClass="stat-label"/>
            <Label text="📝" style="-fx-font-size: 20px; -fx-opacity: 0.5;"/>
        </VBox>
        <VBox styleClass="stat-card-blue" alignment="CENTER" HBox.hgrow="ALWAYS" spacing="5">
            <Label fx:id="lblTotalCategories" text="0" styleClass="stat-number"/>
            <Label text="Catégories" styleClass="stat-label"/>
            <Label text="📁" style="-fx-font-size: 20px; -fx-opacity: 0.5;"/>
        </VBox>
        <VBox styleClass="stat-card-red" alignment="CENTER" HBox.hgrow="ALWAYS" spacing="5">
            <Label fx:id="lblRecentArticles" text="0" styleClass="stat-number"/>
            <Label text="Articles (7j)" styleClass="stat-label"/>
            <Label text="🆕" style="-fx-font-size: 20px; -fx-opacity: 0.5;"/>
        </VBox>
        <VBox styleClass="stat-card-steel" alignment="CENTER" HBox.hgrow="ALWAYS" spacing="5">
            <Label fx:id="lblFeedbackCoverage" text="0%" styleClass="stat-number"/>
            <Label text="Plans avec feedback" styleClass="stat-label"/>
            <Label text="💬" style="-fx-font-size: 20px; -fx-opacity: 0.5;"/>
        </VBox>
    </HBox>

    <!-- ===== GRAPHIQUES ===== -->
    <HBox spacing="14" VBox.vgrow="ALWAYS">
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="8">
            <Label text="Répartition des Plans par Statut"
                   style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #102c59;"/>
            <PieChart fx:id="pieStatut" prefHeight="250" legendSide="BOTTOM"/>
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="8">
            <Label text="Plans par Catégorie"
                   style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #102c59;"/>
            <BarChart fx:id="barCategorie" prefHeight="250">
                <xAxis><CategoryAxis label="Catégorie"/></xAxis>
                <yAxis><NumberAxis label="Nombre"/></yAxis>
            </BarChart>
        </VBox>
    </HBox>

    <!-- ===== LISTE DES RECENT FEEDBACKS ENSEIGNANTS ===== -->
    <VBox styleClass="card" spacing="10">
        <Label text="Derniers Feedbacks Enseignants"
               style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #102c59;"/>
        <Separator/>
        <ScrollPane fitToWidth="true" prefHeight="320"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox fx:id="vboxRecentFeedbacks" spacing="8">
                <!-- Feedbacks load here -->
            </VBox>
        </ScrollPane>
    </VBox>

</VBox>
</content>
</ScrollPane>
