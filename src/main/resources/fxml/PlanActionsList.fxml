<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connection3a36.controllers.PlanActionsListController"
      spacing="16">

    <!-- ===== PAGE HEADER ===== -->
    <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="📋 Plans d'Actions" styleClass="section-title"/>
            <Label text="Gérez les plans d'actions pédagogiques et stratégiques"
                   styleClass="section-subtitle"/>
        </VBox>
        <Button fx:id="btnNewPlan" text="＋ Nouveau Plan" onAction="#handleAdd"
                styleClass="btn-success"/>
        <Button text="📄 Export PDF" onAction="#handleExportPdf" styleClass="btn-warning"/>
    </HBox>

    <!-- ===== BARRE DE RECHERCHE &amp; FILTRES ===== -->
    <HBox styleClass="card" spacing="10" alignment="CENTER_LEFT"
          style="-fx-padding: 12 18;">
        <TextField fx:id="searchField"
                   promptText="🔍 Rechercher (décision, description...)"
                   prefWidth="280" styleClass="search-bar" onAction="#handleSearch"/>
        <ComboBox fx:id="statutFilter" promptText="Statut" prefWidth="150"/>
        <ComboBox fx:id="categorieFilter" promptText="Catégorie" prefWidth="175"/>
        <Button text="Rechercher" onAction="#handleSearch" styleClass="btn-primary"/>
        <Button text="Réinitialiser" onAction="#handleReset" styleClass="btn-secondary"/>
    </HBox>

    <!-- ===== BARRE STATISTIQUES RAPIDES ===== -->
    <HBox fx:id="statsBar" styleClass="stats-bar" spacing="25" alignment="CENTER_LEFT">
        <Label fx:id="lblTotal" text="Total: 0"
               style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #1a1a2e;"/>
        <Label fx:id="lblEnAttente" text="⏳ En attente: 0"
               style="-fx-text-fill: #e67e22; -fx-font-size: 13px; -fx-font-weight: bold;"/>
        <Label fx:id="lblEnCours"   text="🔄 En cours: 0"
               style="-fx-text-fill: #3498db; -fx-font-size: 13px; -fx-font-weight: bold;"/>
        <Label fx:id="lblFini"      text="✅ Terminé: 0"
               style="-fx-text-fill: #27ae60; -fx-font-size: 13px; -fx-font-weight: bold;"/>
        <Label fx:id="lblRejete"    text="❌ Rejeté: 0"
               style="-fx-text-fill: #e74c3c; -fx-font-size: 13px; -fx-font-weight: bold;"/>
    </HBox>

    <!-- ===== TABLE ===== -->
    <TableView fx:id="tablePlans" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colId"       text="ID"        prefWidth="55"/>
            <TableColumn fx:id="colDecision" text="Décision"  prefWidth="260"/>
            <TableColumn fx:id="colStatut"   text="Statut"    prefWidth="115"/>
            <TableColumn fx:id="colCategorie" text="Catégorie" prefWidth="140"/>
            <TableColumn fx:id="colDate"     text="Date"      prefWidth="135"/>
            <TableColumn fx:id="colActions"  text="Actions"   prefWidth="210"/>
        </columns>
        <placeholder>
            <Label text="Aucun plan d'action trouvé. Cliquez sur «Nouveau Plan» pour en créer un."
                   style="-fx-text-fill: #8e92a9; -fx-font-style: italic;"/>
        </placeholder>
    </TableView>

</VBox>
