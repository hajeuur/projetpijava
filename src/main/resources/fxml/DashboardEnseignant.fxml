<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connection3a36.controllers.DashboardEnseignantController"
      spacing="18">

    <!-- ===== PAGE HEADER ===== -->
    <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="Dashboard Enseignant" styleClass="section-title"/>
            <Label text="Vue d'ensemble de vos classes, étudiants et alertes pédagogiques"
                   styleClass="section-subtitle"/>
        </VBox>
    </HBox>

    <!-- ===== CARTES STATISTIQUES ===== -->
    <HBox spacing="15">
        <VBox styleClass="stat-card-blue" alignment="CENTER" HBox.hgrow="ALWAYS" spacing="4" onMouseClicked="#handleGoToAtRisk" style="-fx-cursor: hand;">
            <Label text="42" styleClass="stat-number"/>
            <Label text="Étudiants suivis" styleClass="stat-label"/>
            <Label text="👨‍🎓" style="-fx-font-size: 36px; -fx-text-fill: #102c59;"/>
        </VBox>
        <VBox styleClass="stat-card-green" alignment="CENTER" HBox.hgrow="ALWAYS" spacing="4" onMouseClicked="#handleGoToPlans" style="-fx-cursor: hand;">
            <Label fx:id="lblPlans" text="0" styleClass="stat-number"/>
            <Label text="Mes Plans d'Actions" styleClass="stat-label"/>
            <Label text="📋" style="-fx-font-size: 36px; -fx-text-fill: #102c59;"/>
        </VBox>
        <VBox styleClass="stat-card-orange" alignment="CENTER" HBox.hgrow="ALWAYS" spacing="4" onMouseClicked="#handleGoToArticles" style="-fx-cursor: hand;">
            <Label fx:id="lblArticles" text="0" styleClass="stat-number"/>
            <Label text="Mes Articles / Cours" styleClass="stat-label"/>
            <Label text="📝" style="-fx-font-size: 36px; -fx-text-fill: #102c59;"/>
        </VBox>
        <VBox styleClass="stat-card-red" alignment="CENTER" HBox.hgrow="ALWAYS" spacing="4" onMouseClicked="#handleGoToAtRisk" style="-fx-cursor: hand;">
            <Label text="3" styleClass="stat-number"/>
            <Label text="Alertes Décrochage (IA)" styleClass="stat-label"/>
            <Label text="🚨" style="-fx-font-size: 36px; -fx-text-fill: #102c59;"/>
        </VBox>
    </HBox>

    <!-- ===== TABLEAUX ===== -->
    <HBox spacing="18" VBox.vgrow="ALWAYS">

        <!-- Étudiants à risque -->
        <VBox VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" spacing="12" styleClass="card">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="🛑" style="-fx-font-size: 18px;"/>
                <Label text="Étudiants en risque de décrochage" style="-fx-font-weight: bold; -fx-text-fill: #d32f2f; -fx-font-size: 14px;"/>
            </HBox>
            <TableView fx:id="tableRisk" VBox.vgrow="ALWAYS" styleClass="risk-table">
                <columns>
                    <TableColumn fx:id="colNomRisk"    text="Étudiant"          prefWidth="160"/>
                    <TableColumn fx:id="colScoreRisk"   text="Assiduité (%)"    prefWidth="120"/>
                    <TableColumn fx:id="colMatiereRisk" text="Matière faible"   prefWidth="150"/>
                </columns>
                <placeholder>
                    <Label text="Aucun étudiant à risque détecté"
                           style="-fx-text-fill: #27ae60; -fx-font-style: italic;"/>
                </placeholder>
            </TableView>
        </VBox>

        <!-- Réclamations & Feedback -->
        <VBox VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" spacing="12" styleClass="card">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="💬" style="-fx-font-size: 18px;"/>
                <Label text="Mes Derniers Feedbacks" style="-fx-font-weight: bold; -fx-text-fill: #102c59; -fx-font-size: 14px;"/>
            </HBox>
            <TableView fx:id="tableFeedbacks" VBox.vgrow="ALWAYS" styleClass="feedback-table">
                <columns>
                    <TableColumn fx:id="colFeedbackPlan"    text="Plan d'Action"             prefWidth="170"/>
                    <TableColumn fx:id="colFeedbackTexte"   text="Mon Feedback"              prefWidth="250"/>
                </columns>
                <placeholder>
                    <Label text="Aucun feedback soumis"
                           style="-fx-text-fill: #7a8fa5; -fx-font-style: italic;"/>
                </placeholder>
            </TableView>
        </VBox>
    </HBox>
</VBox>
