<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="mainContainer" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connection3a36.Controller.FrontLayoutController"
            style="-fx-background-color: #f0f4f8;" prefWidth="1200" prefHeight="800">

    <!-- Header / Navbar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #102c59; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 2);">
            <padding><Insets top="15" right="30" bottom="15" left="30"/></padding>

            <!-- Logo -->
            <Label text="MentorAI" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <Region HBox.hgrow="ALWAYS"/> <!-- Espaceur flexible -->

            <!-- Navigation Links -->
            <HBox alignment="CENTER" spacing="15">
                <Button text="Home" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button text="Parcours" onAction="#loadParcours" style="-fx-background-color: transparent; -fx-text-fill: #60a5fa; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button text="Projets" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button text="Contact" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/> <!-- Espaceur flexible -->

            <!-- Profile & Auth -->
            <HBox alignment="CENTER" spacing="10">
                <Label text="👤" style="-fx-font-size: 18px; -fx-text-fill: white;"/>
                <Label fx:id="lblUserName" text="Etudiant" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                <Separator orientation="VERTICAL" style="-fx-padding: 0 5 0 5;"/>
                <Button text="Déconnexion" onAction="#logout"
                        style="-fx-background-color: transparent; -fx-border-color: #d52e28; -fx-border-radius: 50; -fx-text-fill: #d52e28; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 6 15; -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <!-- Center Content -->
    <center>
        <!-- Les vues comme AfficherParcoursFront.fxml y seront injectées -->
    </center>

    <!-- Footer -->
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #0a1a36; -fx-padding: 15;">
            <Label text="© 2026 MentorAI. All Rights Reserved." style="-fx-text-fill: #9dbbce; -fx-font-size: 12px;"/>
        </HBox>
    </bottom>

</BorderPane>
