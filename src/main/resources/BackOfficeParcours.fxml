<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #f1f5f9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connection3a36.controllers.BackOfficeParcoursController">
    <VBox spacing="25" style="-fx-background-color: #f1f5f9; -fx-padding: 30;">
        <!-- Header Area -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Gestion des Parcours" />
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13;" text="Administration" />
                    <Label style="-fx-text-fill: #cbd5e1;" text="•" />
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 13;" text="Liste complète des parcours et formations" />
                </HBox>
            </VBox>
            <Button onAction="#loadData" style="-fx-background-color: white; -fx-text-fill: #0f172a; -fx-background-radius: 10; -fx-padding: 10 25; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2); -fx-cursor: hand;" text="🔃 Actualiser" />
        </HBox>

        <!-- Metrics Section (Moved Up) -->
        <GridPane hgap="25">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3" />
            </columnConstraints>

            <VBox spacing="10" style="-fx-background-color: linear-gradient(to right, #1e3a8a, #3b82f6); -fx-background-radius: 12; -fx-padding: 20;">
                <Label style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12; -fx-font-weight: bold;" text="PARCOURS ACTIFS" />
                <Label fx:id="lblTotalParcours" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: white;" text="0" />
            </VBox>

            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #e2e8f0; -fx-border-radius: 12;" GridPane.columnIndex="1">
                <Label style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: bold;" text="ÉTABLISSEMENTS" />
                <Label fx:id="lblTotalEtab" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="0" />
            </VBox>

            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #e2e8f0; -fx-border-radius: 12;" GridPane.columnIndex="2">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: bold;" text="TOTAL PROJETS" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblTotalProjets" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #3b82f6;" text="0" />
                </HBox>
                <ProgressBar fx:id="progressProjets" maxWidth="Infinity" progress="0.6" style="-fx-accent: #3b82f6; -fx-pref-height: 6;" />
            </VBox>
        </GridPane>

        <!-- MAIN TABLE -->
        <VBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 5);">
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 20; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
                <HBox alignment="CENTER_LEFT" style="-fx-background-color: #f1f5f9; -fx-background-radius: 10; -fx-padding: 0 15;" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: #94a3b8;" text="🔍" />
                    <TextField fx:id="filterInput" onKeyReleased="#filtrerParcours" promptText="Rechercher par titre, institution..." style="-fx-background-color: transparent; -fx-padding: 12; -fx-font-size: 14;" HBox.hgrow="ALWAYS" />
                </HBox>
                <ComboBox fx:id="comboType" prefWidth="200" promptText="Type de parcours" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-padding: 8;" />
            </HBox>

            <TableView fx:id="tableParcours" minHeight="500" style="-fx-background-color: transparent; -fx-selection-bar: #f8fafc; -fx-padding: 10;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colIndex" prefWidth="50" style="-fx-alignment: CENTER;" text="#" />
                    <TableColumn fx:id="colTitreInstitution" prefWidth="350" text="EXPÉRIENCE / FORMATION" />
                    <TableColumn fx:id="colTypeDiplome" prefWidth="220" text="TYPE / DIPLÔME" />
                    <TableColumn fx:id="colPeriode" prefWidth="180" text="PÉRIODE" />
                    <TableColumn fx:id="colProjetsAssocies" prefWidth="100" style="-fx-alignment: CENTER;" text="PROJETS" />
                    <TableColumn fx:id="colAction" prefWidth="110" style="-fx-alignment: CENTER;" text="VOIR" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER" style="-fx-padding: 15; -fx-background-color: #f8fafc; -fx-background-radius: 0 0 15 15;">
                <HBox fx:id="paginationBox" alignment="CENTER" spacing="8" />
            </HBox>
        </VBox>

        <!-- Charts Row -->
        <HBox spacing="25">
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 15, 0, 0, 8);" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Répartition par Type" />
                <PieChart fx:id="pieChartParcours" legendSide="RIGHT" prefHeight="250" />
            </VBox>

            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 15, 0, 0, 8);" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Top Engagements" />
                <BarChart fx:id="barChartProjets" legendVisible="false" prefHeight="250">
                    <xAxis>
                        <CategoryAxis animated="false" side="BOTTOM" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis side="LEFT" tickUnit="1" />
                    </yAxis>
                </BarChart>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
