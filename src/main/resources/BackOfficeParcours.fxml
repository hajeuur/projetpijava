<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-background-color: #f8fafc; -fx-padding: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connection3a36.Controller.BackOfficeParcoursController">
    <Label style="-fx-font-size: 28; -fx-font-weight: bold;" text="Gestion des Parcours" />
    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20;">
        <TextField fx:id="filterInput" onKeyReleased="#filtrerParcours" promptText="Rechercher..." />
        <TableView fx:id="tableParcours">
            <columns>
                <TableColumn fx:id="colTitre" prefWidth="250" text="Titre" />
                <TableColumn fx:id="colType" prefWidth="150" text="Type" />
                <TableColumn fx:id="colEtablissement" prefWidth="200" text="Etablissement" />
                <TableColumn fx:id="colAction" prefWidth="100" text="Action" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
        </TableView>
        <HBox alignment="CENTER" spacing="10">
            <Button onAction="#prevPage" text="&lt; Précédent" />
            <Button onAction="#nextPage" text="Suivant &gt;" />
        </HBox>
    </VBox>
</VBox>
