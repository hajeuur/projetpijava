<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>

<VBox spacing="25" style="-fx-background-color: #f1f5f9; -fx-padding: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connection3a36.controllers.BackOfficeParcoursController">
    <!-- Header Area -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Gestion des Parcours" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Administration" style="-fx-text-fill: #94a3b8; -fx-font-size: 13;"/>
                <Label text="•" style="-fx-text-fill: #cbd5e1;"/>
                <Label text="Liste complète des parcours et formations" style="-fx-text-fill: #64748b; -fx-font-size: 13;"/>
            </HBox>
        </VBox>
        <Button text="🔃 Actualiser" onAction="#loadData"
                style="-fx-background-color: white; -fx-text-fill: #0f172a; -fx-background-radius: 10; -fx-padding: 10 25; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2); -fx-cursor: hand;"/>
    </HBox>

    <!-- MAIN TABLE (Moved to Top) -->
    <VBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 5);">
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 20; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" style="-fx-background-color: #f1f5f9; -fx-background-radius: 10; -fx-padding: 0 15;" HBox.hgrow="ALWAYS">
                <Label text="🔍" style="-fx-text-fill: #94a3b8;"/>
                <TextField fx:id="filterInput" promptText="Rechercher par titre, institution..." onKeyReleased="#filtrerParcours"
                           style="-fx-background-color: transparent; -fx-padding: 12; -fx-font-size: 14;" HBox.hgrow="ALWAYS"/>
            </HBox>
            <ComboBox fx:id="comboType" promptText="Type de parcours" prefWidth="200" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-padding: 8;"/>
        </HBox>

        <TableView fx:id="tableParcours" prefHeight="350"
                   style="-fx-background-color: transparent; -fx-selection-bar: #f8fafc; -fx-padding: 10;">
            <columns>
                <TableColumn fx:id="colIndex" text="#" prefWidth="50" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colTitreInstitution" text="EXPÉRIENCE / FORMATION" prefWidth="350" />
                <TableColumn fx:id="colTypeDiplome" text="TYPE / DIPLÔME" prefWidth="220" />
                <TableColumn fx:id="colPeriode" text="PÉRIODE" prefWidth="180" />
                <TableColumn fx:id="colProjetsAssocies" text="PROJETS" prefWidth="100" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colAction" text="VOIR" prefWidth="110" style="-fx-alignment: CENTER;" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER" style="-fx-padding: 15; -fx-background-color: #f8fafc; -fx-background-radius: 0 0 15 15;">
            <HBox fx:id="paginationBox" spacing="8" alignment="CENTER" />
        </HBox>
    </VBox>

    <!-- Metrics Section (Below Table) -->
    <GridPane hgap="25">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3" />
            <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3" />
            <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3" />
        </columnConstraints>

        <VBox spacing="10" style="-fx-background-color: linear-gradient(to right, #1e3a8a, #3b82f6); -fx-background-radius: 12; -fx-padding: 20;">
            <Label text="PARCOURS ACTIFS" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12; -fx-font-weight: bold;"/>
            <Label fx:id="lblTotalParcours" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>

        <VBox spacing="10" GridPane.columnIndex="1" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #e2e8f0; -fx-border-radius: 12;">
            <Label text="ÉTABLISSEMENTS" style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: bold;"/>
            <Label fx:id="lblTotalEtab" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
        </VBox>

        <VBox spacing="10" GridPane.columnIndex="2" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #e2e8f0; -fx-border-radius: 12;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="TOTAL PROJETS" style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblTotalProjets" text="0" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
            </HBox>
            <ProgressBar fx:id="progressProjets" progress="0.6" maxWidth="Infinity" style="-fx-accent: #3b82f6; -fx-pref-height: 6;"/>
        </VBox>
    </GridPane>

    <!-- Charts Row -->
    <HBox spacing="25">
        <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 15, 0, 0, 8);">
            <Label text="Répartition par Type" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <PieChart fx:id="pieChartParcours" prefHeight="250" legendSide="RIGHT" />
        </VBox>

        <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 15, 0, 0, 8);">
            <Label text="Top Engagements" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <BarChart fx:id="barChartProjets" prefHeight="250" legendVisible="false">
                <xAxis><CategoryAxis side="BOTTOM" animated="false" /></xAxis>
                <yAxis><NumberAxis side="LEFT" tickUnit="1" /></yAxis>
            </BarChart>
        </VBox>
    </HBox>
</VBox>
