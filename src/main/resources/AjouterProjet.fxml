<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connection3a36.Controller.AjouterProjetController"
      spacing="12" style="-fx-background-color: #f4f6f9;" prefWidth="520" prefHeight="520">

    <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>

    <Label text="➕ Nouveau Projet" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    <Label fx:id="lblParcoursNom" text="Parcours : ..."
           style="-fx-font-size: 13px; -fx-text-fill: #8e44ad; -fx-font-style: italic;"/>

    <Label fx:id="lblErreur" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 13px; -fx-wrap-text: true;"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints prefWidth="140"/>
            <ColumnConstraints prefWidth="300" hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Titre *" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtTitre" promptText="Titre du projet (min 3 caractères)"
                   GridPane.rowIndex="0" GridPane.columnIndex="1"
                   style="-fx-background-radius: 6; -fx-padding: 7;"/>
        <Label fx:id="errTitre" text="• Le titre est obligatoire." style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Type *" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="cbType" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="300"/>
        <Label fx:id="errType" text="• Le type est obligatoire." style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Technologies *" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtTechnologies" promptText="Ex: Java, JavaFX, MySQL..."
                   GridPane.rowIndex="4" GridPane.columnIndex="1"
                   style="-fx-background-radius: 6; -fx-padding: 7;"/>
        <Label fx:id="errTechnologies" text="• Les technologies sont obligatoires." style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Description" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextArea fx:id="taDescription" promptText="Description du projet (optionnel)"
                  GridPane.rowIndex="3" GridPane.columnIndex="1"
                  prefRowCount="3" style="-fx-background-radius: 6;" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

        <Label text="Date de Début *" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <DatePicker fx:id="dpDateDebut" GridPane.rowIndex="7" GridPane.columnIndex="1" prefWidth="300"/>
        <Label fx:id="errDateDebut" text="• La date de début est obligatoire." style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false" GridPane.rowIndex="8" GridPane.columnIndex="1"/>

        <Label text="Date de Fin" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dpDateFin" GridPane.rowIndex="9" GridPane.columnIndex="1" prefWidth="300"/>
        <Label fx:id="errDateFin" text="• La date de fin doit être après le début." style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false" GridPane.rowIndex="10" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="15" alignment="CENTER">
        <Button text="💾 Enregistrer" onAction="#enregistrer"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 10 25;"/>
        <Button text="❌ Annuler" onAction="#annuler"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 10 25;"/>
    </HBox>
</VBox>
