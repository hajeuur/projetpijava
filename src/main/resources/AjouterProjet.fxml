<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="edu.connection3a36.controllers.AjouterProjetController"
           style="-fx-background-color: transparent;">

    <!-- Contenu Principal -->
    <VBox spacing="15" style="-fx-background-color: #f8fafc; -fx-background-radius: 15;"
          AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" 
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>

        <!-- Titre Modifié pour Vérification -->
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="🚀 Créer un projet [Assistant IA]" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            
            <Button fx:id="btnFloatingChat" onAction="#toggleChat" 
                    text="✨ Aide IA"
                    style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-background-radius: 10; 
                           -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 5 15;"/>
        </HBox>

        <Label fx:id="lblParcoursNom" text="Parcours : ..." style="-fx-text-fill: #64748b; -fx-font-style: italic;"/>
        
        <Separator/>

        <VBox spacing="8">
            <Label text="Titre du projet *" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
            <TextField fx:id="txtTitre" promptText="Saisissez le titre..." style="-fx-background-radius: 8; -fx-padding: 10;"/>
        </VBox>

        <HBox spacing="15">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Type *" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <ComboBox fx:id="cbType" prefWidth="1000"/>
            </VBox>
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Technologies *" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <TextField fx:id="txtTechnologies" promptText="Java, AI..." style="-fx-background-radius: 8; -fx-padding: 10;"/>
            </VBox>
        </HBox>

        <VBox spacing="8">
            <Label text="Description *" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
            <TextArea fx:id="taDescription" prefRowCount="3" wrapText="true" style="-fx-background-radius: 8;"/>
        </VBox>

        <HBox spacing="15">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Date de Début *" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <DatePicker fx:id="dpDateDebut" prefWidth="1000"/>
            </VBox>
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Date de Fin" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <DatePicker fx:id="dpDateFin" prefWidth="1000"/>
            </VBox>
        </HBox>

        <HBox spacing="15" alignment="CENTER_RIGHT">
            <Button text="Annuler" onAction="#annuler" style="-fx-background-color: transparent; -fx-text-fill: #64748b;"/>
            <Button text="Enregistrer" onAction="#enregistrer" style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 25;"/>
        </HBox>
    </VBox>

    <!-- Overlay Chatbot -->
    <VBox fx:id="paneChat" visible="false" managed="false" prefWidth="300" prefHeight="350" 
          style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);"
          AnchorPane.bottomAnchor="10.0" AnchorPane.rightAnchor="10.0">

        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #1e293b; -fx-background-radius: 15 15 0 0; -fx-padding: 10;">
            <Label text="Assistant" style="-fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" onAction="#toggleChat" style="-fx-background-color: transparent; -fx-text-fill: white;"/>
        </HBox>

        <ScrollPane fx:id="scrollChat" VBox.vgrow="ALWAYS" fitToWidth="true">
            <VBox fx:id="vboxChat" spacing="8" style="-fx-padding: 10;"/>
        </ScrollPane>

        <HBox spacing="5" alignment="CENTER_LEFT" style="-fx-padding: 10;">
            <Button fx:id="btnMic" onAction="#handleMicAction" 
                    style="-fx-background-color: #f1f5f9; -fx-background-radius: 50; -fx-min-width: 35; -fx-min-height: 35; -fx-cursor: hand;">
                <graphic>
                    <StackPane>
                        <javafx.scene.shape.SVGPath fx:id="micIcon" 
                                content="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z M19 10v2a7 7 0 0 1-14 0v-2 M12 19v4 M8 23h8" 
                                fill="#64748b" stroke="#64748b" strokeWidth="1" scaleX="0.8" scaleY="0.8"/>
                    </StackPane>
                </graphic>
            </Button>
            <TextField fx:id="txtChatInput" HBox.hgrow="ALWAYS" promptText="Question..." 
                       style="-fx-background-radius: 15; -fx-padding: 5 10;"/>
            <Button onAction="#envoyerMessage" text="🚀" 
                    style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-background-radius: 50; -fx-min-width: 35; -fx-min-height: 35; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

</AnchorPane>
