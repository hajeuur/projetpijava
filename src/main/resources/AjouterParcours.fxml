<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connection3a36.Controller.AjouterParcoursController"
      spacing="12" style="-fx-background-color: #f4f6f9;" prefWidth="550" prefHeight="700">

    <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>

    <Label text="➕ Nouveau Parcours" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Label fx:id="lblErreur" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 13px; -fx-wrap-text: true;"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints prefWidth="150"/>
            <ColumnConstraints prefWidth="320" hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Type de Parcours *" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="cbTypeParcours" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="320"/>

        <Label text="Titre *" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtTitre" promptText="Titre du parcours (min 3 caractères)" GridPane.rowIndex="1" GridPane.columnIndex="1"
                   style="-fx-background-radius: 6; -fx-padding: 7;"/>

        <Label text="Date de Début *" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <DatePicker fx:id="dpDateDebut" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="320"/>

        <Label text="Date de Fin" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dpDateFin" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="320"/>

        <Label text="Description *" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextArea fx:id="taDescription" promptText="Description du parcours" GridPane.rowIndex="4" GridPane.columnIndex="1"
                  prefRowCount="3" style="-fx-background-radius: 6;"/>

        <Label text="Établissement *" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtEtablissement" promptText="Nom de l'établissement" GridPane.rowIndex="5" GridPane.columnIndex="1"
                   style="-fx-background-radius: 6; -fx-padding: 7;"/>

        <Label text="Diplôme *" GridPane.rowIndex="6" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtDiplome" promptText="Ex: Licence, Master, Ingénieur..." GridPane.rowIndex="6" GridPane.columnIndex="1"
                   style="-fx-background-radius: 6; -fx-padding: 7;"/>

        <Label text="Spécialité" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
        <TextField fx:id="txtSpecialite" promptText="Spécialité (optionnel)" GridPane.rowIndex="7" GridPane.columnIndex="1"
                   style="-fx-background-radius: 6; -fx-padding: 7;"/>

        <Label text="Entreprise" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
        <TextField fx:id="txtEntreprise" promptText="Entreprise (optionnel)" GridPane.rowIndex="8" GridPane.columnIndex="1"
                   style="-fx-background-radius: 6; -fx-padding: 7;"/>

        <Label text="Poste" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
        <TextField fx:id="txtPoste" promptText="Poste occupé (optionnel)" GridPane.rowIndex="9" GridPane.columnIndex="1"
                   style="-fx-background-radius: 6; -fx-padding: 7;"/>

        <Label text="Type Contrat" GridPane.rowIndex="10" GridPane.columnIndex="0"/>
        <TextField fx:id="txtTypeContrat" promptText="CDI, CDD, Alternance... (optionnel)" GridPane.rowIndex="10" GridPane.columnIndex="1"
                   style="-fx-background-radius: 6; -fx-padding: 7;"/>
    </GridPane>

    <HBox spacing="15" alignment="CENTER">
        <Button text="💾 Enregistrer" onAction="#enregistrer"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 10 25;"/>
        <Button text="❌ Annuler" onAction="#annuler"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 10 25;"/>
    </HBox>
</VBox>
