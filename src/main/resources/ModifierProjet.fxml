<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connection3a36.Controller.ModifierProjetController"
      spacing="12" style="-fx-background-color: #f4f6f9;" prefWidth="520" prefHeight="520">

    <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>

    <Label text="✏️ Modifier le Projet" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
    <Label fx:id="lblParcoursNom" text="Parcours : ..."
           style="-fx-font-size: 13px; -fx-text-fill: #8e44ad; -fx-font-style: italic;"/>

    <Label fx:id="lblErreur" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 13px; -fx-wrap-text: true;"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints prefWidth="140"/>
            <ColumnConstraints prefWidth="300" hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Titre *" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtTitre" GridPane.rowIndex="0" GridPane.columnIndex="1"
                   style="-fx-background-radius: 6; -fx-padding: 7;"/>

        <Label text="Type *" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="cbType" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="300"/>

        <Label text="Technologies *" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtTechnologies" GridPane.rowIndex="2" GridPane.columnIndex="1"
                   style="-fx-background-radius: 6; -fx-padding: 7;"/>

        <Label text="Description" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextArea fx:id="taDescription" GridPane.rowIndex="3" GridPane.columnIndex="1"
                  prefRowCount="3" style="-fx-background-radius: 6;"/>

        <Label text="Date de Début *" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <DatePicker fx:id="dpDateDebut" GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="300"/>

        <Label text="Date de Fin" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dpDateFin" GridPane.rowIndex="5" GridPane.columnIndex="1" prefWidth="300"/>
    </GridPane>

    <HBox spacing="15" alignment="CENTER">
        <Button text="💾 Enregistrer" onAction="#enregistrer"
                style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 10 25;"/>
        <Button text="❌ Annuler" onAction="#annuler"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 10 25;"/>
    </HBox>
</VBox>
