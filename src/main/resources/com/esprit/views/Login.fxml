<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.esprit.controllers.LoginController"
            prefHeight="700.0" prefWidth="900.0"
            style="-fx-background-color: #b0c4d8;">

    <VBox alignment="CENTER" spacing="0"
          AnchorPane.topAnchor="40" AnchorPane.bottomAnchor="40"
          AnchorPane.leftAnchor="230" AnchorPane.rightAnchor="230"
          style="-fx-background-color: white; -fx-background-radius: 12;">

        <!-- Header -->
        <VBox alignment="CENTER" spacing="8"
              style="-fx-background-color: #1a2a4a; -fx-background-radius: 12 12 0 0; -fx-padding: 30;">
            <Label text="MentorAI"
                   style="-fx-text-fill: white; -fx-font-size: 26; -fx-font-weight: bold;"/>
            <Label text="Bienvenue"
                   style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
            <Label text="Connectez-vous pour accéder à votre espace"
                   style="-fx-text-fill: #aabbcc; -fx-font-size: 13;"/>
        </VBox>

        <VBox spacing="12" style="-fx-padding: 25;">

            <Label text="Adresse email" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
            <TextField fx:id="emailField" promptText="votre.email@exemple.com"
                       style="-fx-border-color: #cccccc; -fx-border-radius: 6;
                              -fx-background-radius: 6; -fx-padding: 10;"/>

            <Label text="Mot de passe" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
            <PasswordField fx:id="passwordField" promptText="••••••••"
                           style="-fx-border-color: #cccccc; -fx-border-radius: 6;
                                  -fx-background-radius: 6; -fx-padding: 10;"/>

            <HBox alignment="CENTER_RIGHT">
                <Hyperlink text="Mot de passe oublié ?" onAction="#handleForgetPassword"
                           style="-fx-text-fill: #1a2a4a; -fx-font-size: 12;"/>
            </HBox>

            <!-- hCaptcha WebView injecté programmatiquement -->
            <VBox fx:id="captchaContainer"
                  alignment="CENTER"
                  prefHeight="120" minHeight="120" maxHeight="120"/>

            <Label fx:id="errorLabel" text=""
                   style="-fx-text-fill: red; -fx-font-size: 12;"/>

            <!-- Bouton Se connecter TOUJOURS actif -->
            <Button fx:id="loginButton"
                    text="Se connecter"
                    onAction="#handleLogin"
                    maxWidth="Infinity"
                    style="-fx-background-color: #1a2a4a; -fx-text-fill: white;
                           -fx-font-size: 14; -fx-font-weight: bold;
                           -fx-background-radius: 6; -fx-padding: 12;"/>

            <HBox alignment="CENTER" spacing="10">
                <Region HBox.hgrow="ALWAYS"
                        style="-fx-border-color: #cccccc; -fx-border-width: 1 0 0 0;" prefHeight="1"/>
                <Label text="OU" style="-fx-text-fill: #999999; -fx-font-size: 11;"/>
                <Region HBox.hgrow="ALWAYS"
                        style="-fx-border-color: #cccccc; -fx-border-width: 1 0 0 0;" prefHeight="1"/>
            </HBox>

            <Button fx:id="googleLoginButton" onAction="#handleGoogleLogin"
                    maxWidth="Infinity"
                    style="-fx-background-color: white; -fx-border-color: #dddddd;
                           -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10;">
                <graphic>
                    <HBox alignment="CENTER" spacing="10">
                        <Label text="G" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #4285F4;"/>
                        <Label text="Se connecter avec Google"
                               style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #444444;"/>
                    </HBox>
                </graphic>
            </Button>

            <HBox alignment="CENTER" spacing="5">
                <Label text="Pas encore de compte ?"/>
                <Hyperlink text="S'inscrire" onAction="#handleInscription"
                           style="-fx-text-fill: #1a2a4a;"/>
            </HBox>

        </VBox>
    </VBox>
</AnchorPane>
