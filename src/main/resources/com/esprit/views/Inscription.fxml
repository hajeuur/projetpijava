<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.esprit.controllers.InscriptionController"
      spacing="15" style="-fx-padding: 30; -fx-background-color: white;"
      prefWidth="600" prefHeight="620">

    <!-- Header (inchangé) -->
    <VBox style="-fx-background-color: #1d8a6e; -fx-background-radius: 8; -fx-padding: 15;">
        <Label text="Créer un nouvel utilisateur"
               style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
        <Label text="Remplissez le formulaire pour ajouter un nouveau membre"
               style="-fx-text-fill: #cceecc; -fx-font-size: 12;"/>
    </VBox>

    <!-- Formulaire (inchangé) -->
    <HBox spacing="15">
        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <Label text="Prénom *" style="-fx-font-weight: bold;"/>
            <TextField fx:id="prenomField"
                       promptText="Entrez le prénom"
                       style="-fx-border-color: #cccccc; -fx-border-radius: 6;
                              -fx-background-radius: 6; -fx-padding: 8;"/>
        </VBox>
        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <Label text="Nom *" style="-fx-font-weight: bold;"/>
            <TextField fx:id="nomField"
                       promptText="Entrez le nom"
                       style="-fx-border-color: #cccccc; -fx-border-radius: 6;
                              -fx-background-radius: 6; -fx-padding: 8;"/>
        </VBox>
    </HBox>

    <VBox spacing="8">
        <Label text="Adresse email *" style="-fx-font-weight: bold;"/>
        <TextField fx:id="emailField"
                   promptText="exemple@email.com"
                   style="-fx-border-color: #cccccc; -fx-border-radius: 6;
                          -fx-background-radius: 6; -fx-padding: 8;"/>
    </VBox>

    <VBox spacing="8">
        <Label text="Mot de passe *" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="mdpField"
                       promptText="Minimum 8 caractères"
                       style="-fx-border-color: #cccccc; -fx-border-radius: 6;
                              -fx-background-radius: 6; -fx-padding: 8;"/>
    </VBox>

    <VBox spacing="8">
        <Label text="Rôle *" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="roleCombo" maxWidth="Infinity"
                  promptText="Sélectionnez un rôle"
                  style="-fx-border-color: #cccccc; -fx-border-radius: 6;
                         -fx-background-radius: 6;"/>
    </VBox>

    <Label fx:id="errorLabel" style="-fx-text-fill: red; -fx-font-size: 12;"/>
    <Label fx:id="successLabel" style="-fx-text-fill: green; -fx-font-size: 12;"/>

    <!-- Photo de profil -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <javafx.scene.image.ImageView fx:id="photoPreview"
                   fitWidth="80" fitHeight="80"
                   preserveRatio="true"
                   style="-fx-border-color: #cccccc; -fx-border-radius: 40;"/>
        <VBox spacing="6">
            <Label text="Photo de profil (optionnel)" style="-fx-font-weight: bold;"/>
            <Button fx:id="btnChoisirPhoto" text="📷 Choisir une photo"
                    onAction="#handleChoisirPhoto"
                    style="-fx-background-color: #3498db; -fx-text-fill: white;
                           -fx-background-radius: 6; -fx-padding: 8 14; -fx-cursor: hand;"/>
            <Label fx:id="photoPathLabel" text="Aucune photo choisie"
                   style="-fx-text-fill: #888; -fx-font-size: 11;"/>
        </VBox>
    </HBox>

    <!-- Boutons classiques (inchangés) -->
    <HBox spacing="10">
        <Button text="Créer l'utilisateur"
                onAction="#handleCreer"
                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                style="-fx-background-color: #1a2a4a; -fx-text-fill: white;
                       -fx-background-radius: 6; -fx-padding: 12;"/>
        <Button text="Tout effacer"
                onAction="#handleEffacer"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                       -fx-background-radius: 6; -fx-padding: 12;"/>
        <Button text="Retour"
                onAction="#handleRetour"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white;
                       -fx-background-radius: 6; -fx-padding: 12;"/>
    </HBox>

    <!-- Séparateur OU -->
    <HBox alignment="CENTER" spacing="10">
        <Region HBox.hgrow="ALWAYS"
                style="-fx-border-color: #cccccc; -fx-border-width: 1 0 0 0;"
                prefHeight="1"/>
        <Label text="OU"
               style="-fx-text-fill: #999999; -fx-font-size: 11;"/>
        <Region HBox.hgrow="ALWAYS"
                style="-fx-border-color: #cccccc; -fx-border-width: 1 0 0 0;"
                prefHeight="1"/>
    </HBox>

    <!-- Bouton S'inscrire avec Google (nouveau) -->
    <Button fx:id="googleSignupButton"
            onAction="#handleGoogleSignup"
            maxWidth="Infinity"
            style="-fx-background-color: white; -fx-border-color: #dddddd; -fx-border-radius: 6;
                   -fx-background-radius: 6; -fx-padding: 10; -fx-cursor: hand;">
        <graphic>
            <HBox alignment="CENTER" spacing="10">
                <Label text="G"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #4285F4;"/>
                <Label text="S'inscrire avec Google"
                       style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #444444;"/>
            </HBox>
        </graphic>
    </Button>

</VBox>
