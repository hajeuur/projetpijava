<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.esprit.controllers.ProfilUserController"
      spacing="20" style="-fx-padding: 30; -fx-background-color: white;"
      prefWidth="500" prefHeight="450">

    <!-- Header -->
    <VBox alignment="CENTER" spacing="8"
          style="-fx-background-color: #6c5ce7; -fx-background-radius: 8; -fx-padding: 20;">
        <Label fx:id="nomCompletLabel"
               style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
        <Label fx:id="emailHeaderLabel"
               style="-fx-text-fill: #ddd; -fx-font-size: 13;"/>
        <Label fx:id="roleLabel"
               style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                      -fx-background-radius: 4; -fx-padding: 4 12; -fx-font-size: 12;"/>
    </VBox>

    <!-- Informations -->
    <GridPane hgap="20" vgap="15"
              style="-fx-border-color: #eeeeee; -fx-border-radius: 8;
                     -fx-background-color: #f9f9f9; -fx-background-radius: 8; -fx-padding: 20;">

        <Label text="IDENTIFIANT" style="-fx-text-fill: #888; -fx-font-size: 11;"
               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label fx:id="idLabel" style="-fx-font-weight: bold;"
               GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="NOM" style="-fx-text-fill: #888; -fx-font-size: 11;"
               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Label fx:id="nomLabel" style="-fx-font-weight: bold;"
               GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="PRÉNOM" style="-fx-text-fill: #888; -fx-font-size: 11;"
               GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Label fx:id="prenomLabel" style="-fx-font-weight: bold;"
               GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="EMAIL" style="-fx-text-fill: #888; -fx-font-size: 11;"
               GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <Label fx:id="emailLabel" style="-fx-font-weight: bold;"
               GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="RÔLE" style="-fx-text-fill: #888; -fx-font-size: 11;"
               GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <Label fx:id="roleInfoLabel" style="-fx-font-weight: bold;"
               GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="STATUS" style="-fx-text-fill: #888; -fx-font-size: 11;"
               GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <Label fx:id="statusLabel" style="-fx-font-weight: bold;"
               GridPane.columnIndex="1" GridPane.rowIndex="5"/>

    </GridPane>

    <!-- Bouton fermer -->
    <Button text="Fermer"
            onAction="#handleFermer"
            maxWidth="Infinity"
            style="-fx-background-color: #1a2a4a; -fx-text-fill: white;
                   -fx-background-radius: 6; -fx-padding: 10;"/>

</VBox>