<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.esprit.controllers.ResetPasswordController"
            prefHeight="550.0" prefWidth="850.0"
            style="-fx-background-color: #b0c4d8;">

    <VBox alignment="CENTER" spacing="0"
          AnchorPane.topAnchor="60" AnchorPane.bottomAnchor="60"
          AnchorPane.leftAnchor="220" AnchorPane.rightAnchor="220"
          style="-fx-background-color: white; -fx-background-radius: 12;">

        <!-- Header -->
        <VBox alignment="CENTER" spacing="8"
              style="-fx-background-color: #1a2a4a; -fx-background-radius: 12 12 0 0; -fx-padding: 30;">
            <Label text="MentorAI"
                   style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;"/>
            <Label text="Nouveau mot de passe"
                   style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
            <Label text="Entrez le code reçu et votre nouveau mot de passe"
                   style="-fx-text-fill: #aabbcc; -fx-font-size: 12;"/>
        </VBox>

        <!-- Formulaire -->
        <VBox spacing="16" style="-fx-padding: 30;">

            <Label text="Code de réinitialisation"
                   style="-fx-font-weight: bold; -fx-font-size: 13;"/>
            <TextField fx:id="codeField"
                       promptText="Entrez le code reçu par email"
                       style="-fx-border-color: #cccccc; -fx-border-radius: 6;
                              -fx-background-radius: 6; -fx-padding: 10;"/>

            <Label text="Nouveau mot de passe"
                   style="-fx-font-weight: bold; -fx-font-size: 13;"/>
            <PasswordField fx:id="newMdpField"
                           promptText="Minimum 8 caractères"
                           style="-fx-border-color: #cccccc; -fx-border-radius: 6;
                                  -fx-background-radius: 6; -fx-padding: 10;"/>

            <Label text="Confirmer le mot de passe"
                   style="-fx-font-weight: bold; -fx-font-size: 13;"/>
            <PasswordField fx:id="confirmMdpField"
                           promptText="Répétez le mot de passe"
                           style="-fx-border-color: #cccccc; -fx-border-radius: 6;
                                  -fx-background-radius: 6; -fx-padding: 10;"/>

            <Label fx:id="messageLabel"
                   style="-fx-font-size: 12;" text=""/>

            <Button text="Réinitialiser le mot de passe"
                    onAction="#handleReset"
                    maxWidth="Infinity"
                    style="-fx-background-color: #1a2a4a; -fx-text-fill: white;
                           -fx-font-size: 14; -fx-font-weight: bold;
                           -fx-background-radius: 6; -fx-padding: 12;"/>

            <HBox alignment="CENTER">
                <Hyperlink text="Retour au login"
                           onAction="#handleRetour"
                           style="-fx-text-fill: #1a2a4a;"/>
            </HBox>

        </VBox>
    </VBox>
</AnchorPane>