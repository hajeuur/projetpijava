<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-background-color: #f8fafc; -fx-padding: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connection3a36.Controller.BackOfficeProjetsController">
    <HBox alignment="CENTER_LEFT">
        <Label style="-fx-font-size: 28; -fx-font-weight: bold;" text="Gestion des Projets" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#genererPDF" style="-fx-background-color: #2563eb; -fx-text-fill: white;" text="PDF Rapport" />
    </HBox>
    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20;">
        <TextField fx:id="filterInput" onKeyReleased="#filtrar" promptText="Rechercher..." />
        <TableView fx:id="tableProjets">
            <columns>
                <TableColumn fx:id="colTitre" text="Titre" />
                <TableColumn fx:id="colType" text="Type" />
                <TableColumn fx:id="colTechno" text="Techs" />
                <TableColumn fx:id="colAction" text="Action" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
        </TableView>
        <HBox alignment="CENTER" spacing="10">
            <Button onAction="#prevPage" text="&lt; Précédent" />
            <Button onAction="#nextPage" text="Suivant &gt;" />
        </HBox>
    </VBox>
</VBox>
