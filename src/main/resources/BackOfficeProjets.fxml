<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>

<VBox spacing="25" style="-fx-background-color: #f1f5f9; -fx-padding: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connection3a36.Controller.BackOfficeProjetsController">
    <!-- Breadcrumbs / Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Pilotage des Projets" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Dashboard" style="-fx-text-fill: #94a3b8; -fx-font-size: 13;"/>
                <Label text="•" style="-fx-text-fill: #cbd5e1;"/>
                <Label text="Statistiques d'engagement et ressources" style="-fx-text-fill: #64748b; -fx-font-size: 13;"/>
            </HBox>
        </VBox>
        <Button text="🔃 Rafraîchir" onAction="#loadData"
                style="-fx-background-color: white; -fx-text-fill: #1e3a8a; -fx-background-radius: 10; -fx-padding: 10 25; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2); -fx-cursor: hand;"/>
    </HBox>
    
    <!-- Top Row: Bar Charts -->
    <HBox spacing="25">
        <VBox spacing="15" HBox.hgrow="ALWAYS" minWidth="400" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 5);">
            <Label text="Nombre de projets par utilisateur" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <BarChart fx:id="barChartUsers" prefHeight="250" legendVisible="false">
                <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                <yAxis><NumberAxis side="LEFT" label="Projets" /></yAxis>
            </BarChart>
        </VBox>

        <VBox spacing="15" HBox.hgrow="ALWAYS" minWidth="400" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 5);">
            <Label text="Ressources par projet (Top 5)" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <BarChart fx:id="barChartResources" prefHeight="250" legendVisible="false">
                <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                <yAxis><NumberAxis side="LEFT" label="Ressources" /></yAxis>
            </BarChart>
        </VBox>
    </HBox>

    <!-- Mid Row: Donut Chart & Summary Table -->
    <HBox spacing="25" VBox.vgrow="SOMETIMES">
        <VBox spacing="15" prefWidth="400" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 5);">
            <Label text="Distribution par Type" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <PieChart fx:id="pieChartTypes" prefHeight="300" legendSide="BOTTOM" />
        </VBox>

        <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 5);">
            <Label text="Résumé des Performances" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <TableView fx:id="tableSummary" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                <columns>
                    <TableColumn fx:id="colTopUser" text="Utilisateur" />
                    <TableColumn fx:id="colTopProjet" text="Projet Vedette" />
                    <TableColumn fx:id="colProjResCount" text="Score (Ressources)" maxWidth="150" style="-fx-alignment: CENTER;" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            </TableView>
        </VBox>
    </HBox>

    <!-- Bottom: Main Project Table -->
    <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="15">
            <HBox alignment="CENTER_LEFT" style="-fx-background-color: #f1f5f9; -fx-background-radius: 10; -fx-padding: 0 15;" HBox.hgrow="ALWAYS">
                <Label text="🔍" style="-fx-text-fill: #94a3b8;"/>
                <TextField fx:id="filterInput" promptText="Filtrer les projets..." onKeyReleased="#filtrar"
                           style="-fx-background-color: transparent; -fx-padding: 12; -fx-font-size: 14;" HBox.hgrow="ALWAYS"/>
            </HBox>
            <Button text="📄 Exporter PDF" onAction="#genererPDF" 
                    style="-fx-background-color: #fee2e2; -fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12 25; -fx-cursor: hand;"/>
        </HBox>

        <TableView fx:id="tableProjets" prefHeight="350">
            <columns>
                <TableColumn fx:id="colIndex" text="#" prefWidth="50" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colTitre" text="PROJET" />
                <TableColumn fx:id="colUtilisateur" text="PROPRIÉTAIRE" prefWidth="200" />
                <TableColumn fx:id="colType" text="TYPE" prefWidth="150" />
                <TableColumn fx:id="colRessources" text="RESSOURCES" />
                <TableColumn fx:id="colAction" text="VOIR" prefWidth="80" style="-fx-alignment: CENTER;" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
        </TableView>

        <!-- Dynamic Pagination Box -->
        <HBox fx:id="paginationBoxProjets" alignment="CENTER" spacing="10" />
    </VBox>
</VBox>
