<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.Text?>

<StackPane xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="edu.connection3a36.controllers.EntretienIAController"
           style="-fx-background-color: #f8fafc;">

    <VBox spacing="0">
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #1e293b; -fx-padding: 20;">
            <Button text="← Quitter" onAction="#quitter" 
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 5; -fx-cursor: hand;"/>
            <VBox>
                <Label text="🎙️ Entretien Blanc IA" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Pratiquez vos entretiens avec MentorAI" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="10" style="-fx-background-color: rgba(99, 102, 241, 0.2); -fx-padding: 8 15; -fx-background-radius: 20;">
                <Circle radius="4" fill="#22c55e"/>
                <Label fx:id="lblStatus" text="En attente..." style="-fx-text-fill: #818cf8; -fx-font-weight: bold;"/>
            </HBox>
        </HBox>

        <HBox VBox.vgrow="ALWAYS" spacing="0">
            <!-- Left: Interview Area -->
            <VBox HBox.hgrow="ALWAYS" spacing="20" style="-fx-padding: 30;">
                <!-- Question Card -->
                <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Circle radius="15" fill="#6366f1"/>
                        <Label text="MentorAI" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    </HBox>
                    <javafx.scene.text.TextFlow fx:id="flowQuestion" 
                           onMouseClicked="#zoomQuestion" maxWidth="800" 
                           style="-fx-font-size: 18px; -fx-line-spacing: 5; -fx-cursor: hand;"/>
                </VBox>

                <!-- User Answer Area -->
                <VBox spacing="15" VBox.vgrow="ALWAYS">
                    <Label text="VOTRE RÉPONSE" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-letter-spacing: 1px; -fx-font-size: 11px;"/>
                    <TextArea fx:id="txtAnswer" VBox.vgrow="ALWAYS" editable="false" wrapText="true" promptText="Votre réponse apparaîtra ici après l'enregistrement..."
                              style="-fx-background-radius: 15; -fx-padding: 15; -fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 15; -fx-font-size: 15px;"/>
                </VBox>

                <!-- Controls -->
                <HBox spacing="20" alignment="CENTER">
                    <Button fx:id="btnStart" text="Démarrer l'entretien" onAction="#demarrerEntretien"
                            style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 30; -fx-background-radius: 10; -fx-cursor: hand;"/>
                    
                    <Button fx:id="btnMic" onAction="#handleMicAction" visible="false" managed="false"
                            style="-fx-background-color: #f1f5f9; -fx-background-radius: 50; -fx-min-width: 60; -fx-min-height: 60; -fx-cursor: hand;">
                        <graphic>
                            <javafx.scene.shape.SVGPath fx:id="micIcon" 
                                    content="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z M19 10v2a7 7 0 0 1-14 0v-2 M12 19v4 M8 23h8" 
                                    fill="#64748b" stroke="#64748b" strokeWidth="1" scaleX="1.2" scaleY="1.2"/>
                        </graphic>
                    </Button>

                    <Button fx:id="btnNext" text="Question suivante →" onAction="#prochaineQuestion" visible="false" managed="false"
                            style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 30; -fx-background-radius: 10; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- Right: Evaluation & Tips -->
            <VBox fx:id="paneEvaluation" spacing="20" prefWidth="350" minWidth="350" visible="false" managed="false"
                  style="-fx-background-color: #f1f5f9; -fx-padding: 30; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 0 1;">
                
                <Label text="ANALYSE DE L'IA" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                
                <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15;">
                    <Label text="Score de la réponse" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                    <Label fx:id="lblScore" text="--/10" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #6366f1;"/>
                    <ProgressBar fx:id="progressScore" progress="0" maxWidth="Infinity" prefHeight="8" 
                                 style="-fx-accent: #6366f1;"/>
                </VBox>

                <VBox spacing="10" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 2);">
                    <Label text="Points forts &amp; Améliorations" wrapText="true" maxWidth="250" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                        <Label fx:id="lblFeedback" text="..." wrapText="true" maxWidth="250" style="-fx-text-fill: #475569; -fx-line-spacing: 5; -fx-font-size: 13px;"/>
                    </ScrollPane>
                </VBox>

                <VBox spacing="10" style="-fx-background-color: #dcfce7; -fx-padding: 15; -fx-background-radius: 10;">
                    <Label text="💡 Conseil Pro" style="-fx-font-weight: bold; -fx-text-fill: #166534; -fx-font-size: 12px;"/>
                    <Label fx:id="lblTip" text="Préparez une anecdote concrète pour illustrer chaque compétence mentionnée." 
                           wrapText="true" style="-fx-text-fill: #166534; -fx-font-size: 12px;"/>
                </VBox>
            </VBox>
        </HBox>
    </VBox>

    <!-- Loading Overlay -->
    <VBox fx:id="paneLoading" alignment="CENTER" spacing="20" visible="false" 
          style="-fx-background-color: rgba(255,255,255,0.8);">
        <ProgressIndicator prefWidth="50" prefHeight="50"/>
        <Label fx:id="lblLoadingText" text="MentorAI prépare la question..." style="-fx-font-weight: bold; -fx-text-fill: #6366f1;"/>
    </VBox>

</StackPane>
