<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Line?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #f8fafc;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connection3a36.controllers.AboutController">
    <VBox alignment="CENTER" spacing="50" style="-fx-background-color: #f8fafc;">
        <padding>
            <Insets bottom="60" left="40" right="40" top="60" />
        </padding>

        <HBox alignment="CENTER" spacing="80">
            <!-- Left Side: Content -->
            <VBox spacing="30" maxWidth="500">
                <VBox spacing="15">
                    <Label style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-padding: 4 12; -fx-background-radius: 20; -fx-font-size: 11px; -fx-font-weight: bold;" text="Innovation &amp; Technologie" />
                    
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Line endX="40" stroke="#e74c3c" strokeWidth="2" />
                        <Label style="-fx-text-fill: #1e293b; -fx-font-size: 32px; -fx-font-weight: bold;" text="À propos de MentorAI" />
                        <Line endX="40" stroke="#e74c3c" strokeWidth="2" />
                    </HBox>
                </VBox>

                <VBox spacing="20">
                    <Label style="-fx-text-fill: #475569; -fx-font-size: 18px; -fx-wrap-text: true;" text="Votre plateforme intelligente d'accompagnement et de gestion de carrière." />
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 15px; -fx-wrap-text: true; -fx-line-spacing: 5;" text="MentorAI combine la puissance de l'intelligence artificielle avec une approche centrée sur l'humain pour vous aider à atteindre vos objectifs professionnels." />
                </VBox>

                <VBox spacing="15">
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="✓" style="-fx-background-color: #dbeafe; -fx-text-fill: #2563eb; -fx-padding: 5; -fx-background-radius: 50; -fx-min-width: 25; -fx-alignment: center; -fx-font-weight: bold;"/>
                        <Label text="Suivi de progression personnalisé" style="-fx-text-fill: #1e293b; -fx-font-size: 16px;"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="✓" style="-fx-background-color: #dbeafe; -fx-text-fill: #2563eb; -fx-padding: 5; -fx-background-radius: 50; -fx-min-width: 25; -fx-alignment: center; -fx-font-weight: bold;"/>
                        <Label text="IA Chatbot intégrée" style="-fx-text-fill: #1e293b; -fx-font-size: 16px;"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="✓" style="-fx-background-color: #dbeafe; -fx-text-fill: #2563eb; -fx-padding: 5; -fx-background-radius: 50; -fx-min-width: 25; -fx-alignment: center; -fx-font-weight: bold;"/>
                        <Label text="Gestion de projets et parcours" style="-fx-text-fill: #1e293b; -fx-font-size: 16px;"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Right Side: QR Code Card -->
            <VBox alignment="CENTER" spacing="20" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 30, 0, 0, 10); -fx-padding: 40; -fx-min-width: 400;">
                <Label style="-fx-text-fill: #1e293b; -fx-font-size: 24px; -fx-font-weight: bold;" text="Accès Mobile Rapide" />
                <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px; -fx-text-alignment: center; -fx-wrap-text: true;" maxWidth="300" text="Scannez ce QR code pour accéder instantanément au site sur votre téléphone." />
                
                <StackPane style="-fx-background-color: #f8fafc; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #e2e8f0; -fx-border-radius: 15;">
                    <ImageView fx:id="qrCodeImageView" fitHeight="200" fitWidth="200" preserveRatio="true" />
                </StackPane>

                <VBox alignment="CENTER" spacing="10">
                    <Separator maxWidth="300" />
                    <HBox alignment="CENTER" spacing="8">
                        <Label text="🌐" style="-fx-font-size: 14px;"/>
                        <Label fx:id="ipLabel" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;" text="Chargement de l'adresse..." />
                    </HBox>
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-font-style: italic;" text="Le téléphone doit être sur le même Wi-Fi." />
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
