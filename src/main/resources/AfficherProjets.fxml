<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connection3a36.Controller.AfficherProjetsController"
            style="-fx-background-color: #f0f4f8;" fitToWidth="true" prefWidth="1200" prefHeight="800">
            
    <VBox spacing="0" style="-fx-background-color: #f0f4f8;">
        
        <!-- Top Blue Banner -->
        <VBox alignment="CENTER" style="-fx-background-color: #102c59; -fx-padding: 30 0;">
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 0 50;">
                <Button text="← Retour" onAction="#retour" 
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 5; -fx-cursor: hand;"/>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                    <Label text="Gestion des Projets" style="-fx-font-size: 32px; -fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Label text="Gérez vos réalisations académiques et professionnelles ainsi que leurs ressources." style="-fx-font-size: 15px; -fx-text-fill: #9dbbce; -fx-padding: 5 0 0 0;"/>
                </VBox>
                <Region prefWidth="100"/> <!-- Balance -->
            </HBox>
        </VBox>
        
        <!-- Main Content -->
        <HBox spacing="30" style="-fx-padding: 30;">
            
            <!-- Left Sidebar -->
            <VBox spacing="15" prefWidth="320" minWidth="300">
                <Button fx:id="btnAjouter" text="+ Nouveau Projet" onAction="#preparerAjout" maxWidth="Infinity" 
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 8; -fx-padding: 12; -fx-cursor: hand;"/>
                
                <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);" VBox.vgrow="ALWAYS">
                    <Label text="Mes Projets" style="-fx-font-weight: bold; -fx-text-fill: #102c59; -fx-font-size: 14px; -fx-padding: 15;"/>
                    <Separator/>
                    <ListView fx:id="listProjets" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 5;"/>
                </VBox>
                
                <Button fx:id="btnSupprimer" text="🗑 Supprimer la sélection" onAction="#supprimerProjet" maxWidth="Infinity" 
                        style="-fx-background-color: transparent; -fx-border-color: #e74c3c; -fx-text-fill: #e74c3c; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 10; -fx-cursor: hand;"/>
            </VBox>
            
            <!-- Right Content: Formulaire -->
            <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 20, 0, 0, 5);" spacing="20">
                <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>
                
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="📁" style="-fx-font-size: 26px;"/>
                    <Label fx:id="lblFormTitle" text="Créer un projet" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #102c59;"/>
                </HBox>
                
                <!-- "Tabs" simulation -->
                <HBox spacing="30" style="-fx-border-color: transparent transparent #e0e0e0 transparent; -fx-border-width: 0 0 2 0;">
                    <Label text="ℹ Informations" style="-fx-font-weight: bold; -fx-text-fill: #102c59; -fx-border-color: transparent transparent #e74c3c transparent; -fx-border-width: 0 0 3 0; -fx-padding: 10 5;"/>
                    <Label fx:id="lblTabRessources" text="🔗 Ressources" onMouseClicked="#ouvrirRessources" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d; -fx-padding: 10 5; -fx-cursor: hand;"/>
                </HBox>
                
                <Label fx:id="lblErreur" text="" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;" wrapText="true"/>
                
                <!-- Grid Form -->
                <GridPane vgap="25" hgap="30">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50" />
                        <ColumnConstraints percentWidth="50" />
                    </columnConstraints>
                    
                    <VBox GridPane.rowIndex="0" GridPane.columnIndex="0" spacing="8">
                        <Label text="Titre du projet *" style="-fx-font-weight: bold; -fx-text-fill: #102c59; -fx-font-size: 13px;"/>
                        <TextField fx:id="txtTitre" style="-fx-background-radius: 6; -fx-border-color: #dcdde1; -fx-border-radius: 6; -fx-padding: 10; -fx-font-size: 14px;"/>
                        <Label fx:id="errTitre" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false"/>
                    </VBox>
                    
                    <VBox GridPane.rowIndex="0" GridPane.columnIndex="1" spacing="8">
                        <Label text="Type de projet *" style="-fx-font-weight: bold; -fx-text-fill: #102c59; -fx-font-size: 13px;"/>
                        <TextField fx:id="txtType" promptText="Web, Mobile..." style="-fx-background-radius: 6; -fx-border-color: #dcdde1; -fx-border-radius: 6; -fx-padding: 10; -fx-font-size: 14px;"/>
                        <Label fx:id="errType" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false"/>
                    </VBox>
                    
                    <VBox GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.columnSpan="2" spacing="8">
                        <Label text="Description *" style="-fx-font-weight: bold; -fx-text-fill: #102c59; -fx-font-size: 13px;"/>
                        <TextArea fx:id="taDescription" prefRowCount="4" wrapText="true" style="-fx-background-radius: 6; -fx-border-color: #dcdde1; -fx-border-radius: 6; -fx-padding: 4; -fx-font-size: 14px;"/>
                        <Label fx:id="errDescription" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false"/>
                    </VBox>
                    
                    <VBox GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="2" spacing="8">
                        <Label text="Technologies utilisées" style="-fx-font-weight: bold; -fx-text-fill: #102c59; -fx-font-size: 13px;"/>
                        <TextField fx:id="txtTechnologies" promptText="PHP, Symfony, Bootstrap..." style="-fx-background-radius: 6; -fx-border-color: #dcdde1; -fx-border-radius: 6; -fx-padding: 10; -fx-font-size: 14px;"/>
                        <Label fx:id="errTechnologies" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false"/>
                    </VBox>
                    
                    <VBox GridPane.rowIndex="3" GridPane.columnIndex="0" spacing="8">
                        <Label text="Date de début *" style="-fx-font-weight: bold; -fx-text-fill: #102c59; -fx-font-size: 13px;"/>
                        <DatePicker fx:id="dpDateDebut" promptText="jj/mm/aaaa" maxWidth="Infinity" style="-fx-background-radius: 6; -fx-border-color: #dcdde1; -fx-border-radius: 6; -fx-padding: 5; -fx-font-size: 14px;"/>
                        <Label fx:id="errDateDebut" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false"/>
                    </VBox>
                    
                    <VBox GridPane.rowIndex="3" GridPane.columnIndex="1" spacing="8">
                        <Label text="Date de fin" style="-fx-font-weight: bold; -fx-text-fill: #102c59; -fx-font-size: 13px;"/>
                        <DatePicker fx:id="dpDateFin" promptText="jj/mm/aaaa" maxWidth="Infinity" style="-fx-background-radius: 6; -fx-border-color: #dcdde1; -fx-border-radius: 6; -fx-padding: 5; -fx-font-size: 14px;"/>
                        <Label fx:id="errDateFin" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false"/>
                    </VBox>

                    <VBox GridPane.rowIndex="4" GridPane.columnIndex="0" GridPane.columnSpan="2" spacing="8">
                        <Label text="Parcours Associé" style="-fx-font-weight: bold; -fx-text-fill: #102c59; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="cbParcours" maxWidth="Infinity" promptText="Sélectionner un parcours (optionnel)" style="-fx-background-radius: 6; -fx-border-color: #dcdde1; -fx-border-radius: 6; -fx-padding: 5; -fx-font-size: 14px;"/>
                    </VBox>
                </GridPane>
                
                <Region VBox.vgrow="ALWAYS"/>
                <Separator style="-fx-padding: 10 0;"/>
                
                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <Button fx:id="btnEnregistrer" text="💾 Enregistrer le projet" onAction="#enregistrerProjet" 
                            style="-fx-background-color: #102c59; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 10 35; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(16,44,89,0.3), 8, 0, 0, 2);"/>
                </HBox>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
