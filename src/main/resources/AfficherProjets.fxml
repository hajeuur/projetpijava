<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="edu.connection3a36.controllers.AfficherProjetsController"
           style="-fx-background-color: #f0f4f8;">

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox spacing="0">
            <!-- Top Blue Banner -->
            <VBox alignment="CENTER" style="-fx-background-color: #102c59; -fx-padding: 30 0;">
                <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 0 50;">
                    <Button text="← Retour" onAction="#retour" 
                            style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 5; -fx-cursor: hand;"/>
                    
                    <HBox alignment="CENTER_LEFT" spacing="20" HBox.hgrow="ALWAYS">
                        <VBox alignment="CENTER_LEFT">
                            <Label text="Gestion des Projets" style="-fx-font-size: 32px; -fx-text-fill: white; -fx-font-weight: bold;"/>
                            <Label text="Gérez vos réalisations académiques et professionnelles ainsi que leurs ressources." style="-fx-font-size: 15px; -fx-text-fill: #9dbbce; -fx-padding: 5 0 0 0;"/>
                        </VBox>
                        
                        <Button fx:id="btnToggleChat" onAction="#toggleChat"
                                style="-fx-background-color: linear-gradient(to right, #6366f1, #a855f7); -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20; -fx-font-weight: bold; -fx-cursor: hand;">
                            <graphic>
                                <HBox spacing="8" alignment="CENTER">
                                    <Text text="✨" style="-fx-fill: white; -fx-font-size: 16px;"/>
                                    <Label text="Assistant MentorAI" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                                </HBox>
                            </graphic>
                        </Button>
                    </HBox>
                </HBox>
            </VBox>
            
            <!-- Main Content -->
            <HBox spacing="25" style="-fx-padding: 25;">
                <!-- Left Sidebar -->
                <VBox spacing="15" prefWidth="300" minWidth="280">
                    <Button fx:id="btnAjouter" text="+ Nouveau Projet" onAction="#preparerAjout" maxWidth="Infinity" 
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 12; -fx-cursor: hand;"/>
                    
                    <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);" VBox.vgrow="ALWAYS">
                        <Label text="Mes Projets" style="-fx-font-weight: bold; -fx-text-fill: #102c59; -fx-font-size: 14px; -fx-padding: 15;"/>
                        <Separator/>
                        <ListView fx:id="listProjets" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
                        <Separator/>
                        <Button fx:id="btnSupprimer" text="🗑 Supprimer" onAction="#supprimerProjet" maxWidth="Infinity" 
                                style="-fx-background-color: transparent; -fx-text-fill: #e74c3c; -fx-padding: 12; -fx-cursor: hand;"/>
                    </VBox>
                </VBox>
                
                <!-- Right Content Form (LE FORMULAIRE CORRIGÉ) -->
                <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 5);" spacing="0">
                    <VBox spacing="20">
                        <padding><Insets top="25" right="35" bottom="25" left="35"/></padding>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Text text="📁" style="-fx-font-size: 20px; -fx-fill: #102c59;"/>
                            <Label fx:id="lblFormTitle" text="Créer un projet" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #102c59;"/>
                        </HBox>

                        <!-- Onglets Stylisés (Comme l'image 43) -->
                        <HBox spacing="30" style="-fx-border-color: transparent transparent #edf2f7 transparent; -fx-border-width: 0 0 2 0;">
                            <Label text="ℹ Informations" style="-fx-padding: 0 0 8 0; -fx-border-color: transparent transparent #e74c3c transparent; -fx-border-width: 0 0 3 0; -fx-font-weight: bold; -fx-text-fill: #102c59;"/>
                            <Label fx:id="lblTabRessources" text="🔗 Ressources" onMouseClicked="#ouvrirRessources" style="-fx-padding: 0 0 8 0; -fx-cursor: hand; -fx-text-fill: #718096; -fx-font-weight: bold;"/>
                        </HBox>

                        <Label fx:id="lblErreur" text="" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;" wrapText="true"/>
                        
                        <!-- Le Formulaire avec Labels visibles -->
                        <GridPane vgap="25" hgap="30">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50" />
                                <ColumnConstraints percentWidth="50" />
                            </columnConstraints>
                            
                            <!-- Titre -->
                            <VBox GridPane.rowIndex="0" GridPane.columnIndex="0" spacing="8">
                                <Label text="Titre du projet" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                                <TextField fx:id="txtTitre" style="-fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;"/>
                                <Label fx:id="errTitre" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false"/>
                            </VBox>
                            
                            <!-- Type -->
                            <VBox GridPane.rowIndex="0" GridPane.columnIndex="1" spacing="8">
                                <Label text="Type de projet" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                                <TextField fx:id="txtType" promptText="Web, Mobile, AI..." style="-fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;"/>
                                <Label fx:id="errType" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false"/>
                            </VBox>
                            
                            <!-- Description -->
                            <VBox GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.columnSpan="2" spacing="8">
                                <Label text="Description" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                                <TextArea fx:id="taDescription" prefRowCount="4" wrapText="true" style="-fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 5;"/>
                                <Label fx:id="errDescription" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false"/>
                            </VBox>
                            
                            <!-- Technologies -->
                            <VBox GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="2" spacing="8">
                                <Label text="Technologies utilisées" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                                <TextField fx:id="txtTechnologies" promptText="PHP, Symfony, Bootstrap..." style="-fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;"/>
                                <Label fx:id="errTechnologies" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false"/>
                            </VBox>
                            
                            <!-- Dates -->
                            <VBox GridPane.rowIndex="3" GridPane.columnIndex="0" spacing="8">
                                <Label text="Date de début" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                                <DatePicker fx:id="dpDateDebut" maxWidth="Infinity" style="-fx-background-radius: 8; -fx-border-radius: 8;"/>
                                <Label fx:id="errDateDebut" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false"/>
                            </VBox>
                            
                            <VBox GridPane.rowIndex="3" GridPane.columnIndex="1" spacing="8">
                                <Label text="Date de fin" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                                <DatePicker fx:id="dpDateFin" maxWidth="Infinity" style="-fx-background-radius: 8; -fx-border-radius: 8;"/>
                                <Label fx:id="errDateFin" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" visible="false" managed="false"/>
                            </VBox>

                            <!-- Parcours -->
                            <VBox GridPane.rowIndex="4" GridPane.columnIndex="0" GridPane.columnSpan="2" spacing="8">
                                <Label text="Parcours Associé" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                                <ComboBox fx:id="cbParcours" maxWidth="Infinity" promptText="Sélectionner un parcours" style="-fx-background-radius: 8; -fx-border-radius: 8;"/>
                            </VBox>
                        </GridPane>
                        
                        <Separator style="-fx-padding: 10 0;"/>
                        
                        <HBox spacing="15" alignment="CENTER_RIGHT">
                            <Button fx:id="btnEnregistrer" text="💾 Enregistrer le projet" onAction="#enregistrerProjet" 
                                    style="-fx-background-color: #102c59; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 10 30; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </ScrollPane>

    <!-- Overlay Chatbot Fenêtre Flottante -->
    <VBox fx:id="paneChat" visible="false" managed="false" maxWidth="350" maxHeight="500" 
          style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 20, 0, 0, 10);"
          StackPane.alignment="BOTTOM_RIGHT">
        <StackPane.margin><Insets bottom="20" right="20"/></StackPane.margin>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #1e293b; -fx-background-radius: 20 20 0 0; -fx-padding: 15;">
            <Circle radius="5" fill="#22c55e"/>
            <Label text="Assistant MentorAI" style="-fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" onAction="#toggleChat" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"/>
        </HBox>
        <ScrollPane fx:id="scrollChat" VBox.vgrow="ALWAYS" fitToWidth="true" style="-fx-background: white; -fx-padding: 10;">
            <VBox fx:id="vboxChat" spacing="10"/>
        </ScrollPane>
        <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;">
            <Button fx:id="btnMic" onAction="#handleMicAction" 
                    style="-fx-background-color: #f1f5f9; -fx-background-radius: 50; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                <graphic>
                    <StackPane>
                        <javafx.scene.shape.SVGPath fx:id="micIcon" 
                                content="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z M19 10v2a7 7 0 0 1-14 0v-2 M12 19v4 M8 23h8" 
                                fill="#64748b" stroke="#64748b" strokeWidth="1"/>
                    </StackPane>
                </graphic>
            </Button>
            <TextField fx:id="txtChatInput" HBox.hgrow="ALWAYS" promptText="Écris un message..." 
                       style="-fx-background-radius: 20; -fx-padding: 8 15; -fx-border-color: #e2e8f0; -fx-border-radius: 20;"/>
            <Button onAction="#envoyerMessageChat" text="🚀" 
                    style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-background-radius: 50; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

</StackPane>
