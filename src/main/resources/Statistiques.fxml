<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connection3a36.controllers.StatistiquesController"
      spacing="25" style="-fx-background-color: #f8fafc;" prefWidth="1200" prefHeight="850">
    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Analyse Globale de l'Activité" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
    </HBox>

    <HBox spacing="25" VBox.vgrow="ALWAYS">
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 15, 0, 0, 8);"
              HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Utilisateurs avec le plus de projets" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER_LEFT" spacing="5">
                    <Region prefWidth="30" prefHeight="10" style="-fx-background-color: #0f172a;"/>
                    <Label text="Nombre de Projets" style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
                </HBox>
            </HBox>
            <BarChart fx:id="barChartProjets" legendVisible="false" VBox.vgrow="ALWAYS" animated="false">
                <xAxis><CategoryAxis side="BOTTOM" animated="false" /></xAxis>
                <yAxis><NumberAxis side="LEFT" tickUnit="1" /></yAxis>
            </BarChart>
        </VBox>

        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 15, 0, 0, 8);"
              HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Projets avec le plus de ressources" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER_LEFT" spacing="5">
                    <Region prefWidth="30" prefHeight="10" style="-fx-background-color: #166534;"/>
                    <Label text="Nombre de Ressources" style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
                </HBox>
            </HBox>
            <BarChart fx:id="barChartRessources" legendVisible="false" VBox.vgrow="ALWAYS" animated="false">
                <xAxis><NumberAxis side="BOTTOM" tickUnit="1" /></xAxis>
                <yAxis><CategoryAxis side="LEFT" animated="false"/></yAxis>
            </BarChart>
        </VBox>
    </HBox>

    <HBox spacing="25" VBox.vgrow="ALWAYS">
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 15, 0, 0, 8);"
              HBox.hgrow="ALWAYS" maxWidth="450">
            <Label text="Répartition par Type" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <StackPane VBox.vgrow="ALWAYS">
                <PieChart fx:id="pieChartTypeProjet" legendSide="BOTTOM" />
                <Region maxWidth="120" maxHeight="120" style="-fx-background-color: white; -fx-background-radius: 1000;"/>
            </StackPane>
        </VBox>

        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 15, 0, 0, 8);"
              HBox.hgrow="ALWAYS">
            <Label text="Résumé des Tops" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-padding: 0 0 15 0;"/>
            <TableView fx:id="tableTops" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: #f1f5f9; -fx-table-cell-border-color: #f1f5f9;">
                <columns>
                    <TableColumn fx:id="colTopParcours" text="Top Utilisateur" prefWidth="180"/>
                    <TableColumn fx:id="colParcoursProjets" text="Projets" prefWidth="80" style="-fx-alignment: CENTER_LEFT;"/>
                    <TableColumn fx:id="colTopProjet" text="Top Projet" prefWidth="300"/>
                    <TableColumn fx:id="colProjetRessources" text="Ressources" prefWidth="100" style="-fx-alignment: CENTER_LEFT;"/>
                </columns>
                <placeholder><Label text="Aucune donnée disponible"/></placeholder>
            </TableView>
        </VBox>
    </HBox>
</VBox>
