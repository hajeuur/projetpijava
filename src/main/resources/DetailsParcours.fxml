<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<VBox spacing="20" style="-fx-background-color: #f8fafc; -fx-padding: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connection3a36.controllers.DetailsParcoursController">
    <!-- Header with Back Button -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button text="← Retour" onAction="#retour" 
                style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 8 15; -fx-cursor: hand; -fx-text-fill: #64748b;"/>
        <VBox>
            <Label fx:id="lblTitre" text="Détails du Parcours" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <HBox spacing="5">
                <Label text="Parcours" style="-fx-text-fill: #64748b;"/>
                <Label text="/" style="-fx-text-fill: #94a3b8;"/>
                <Label fx:id="lblTypeBadge" text="Formation" style="-fx-text-fill: #3b82f6; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </HBox>

    <HBox spacing="25">
        <!-- Main Details Card -->
        <VBox spacing="20" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 5);">
            <GridPane hgap="30" vgap="15">
                <columnConstraints>
                    <ColumnConstraints minWidth="100" prefWidth="150" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>
                
                <Label text="Établissement / Entreprise" style="-fx-text-fill: #94a3b8; -fx-font-size: 13;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="lblEtablissement" text="---" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1e293b;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                
                <Label text="Diplôme / Poste" style="-fx-text-fill: #94a3b8; -fx-font-size: 13;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="lblDiplome" text="---" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1e293b;" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                
                <Label text="Spécialité" style="-fx-text-fill: #94a3b8; -fx-font-size: 13;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="lblSpecialite" text="---" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1e293b;" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                
                <Label text="Période" style="-fx-text-fill: #94a3b8; -fx-font-size: 13;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <Label fx:id="lblPeriode" text="---" style="-fx-font-size: 14; -fx-text-fill: #1e293b;" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            </GridPane>
            
            <Separator />
            
            <VBox spacing="10">
                <Label text="Description" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label fx:id="lblDescription" text="..." wrapText="true" style="-fx-text-fill: #64748b; -fx-line-spacing: 1.5;"/>
            </VBox>
        </VBox>

        <!-- Right Side: Projects List Card -->
        <VBox spacing="15" prefWidth="400" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 5);">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="📂 Projets Associés" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #1e293b;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblProjetsCount" text="0" style="-fx-background-color: #f1f5f9; -fx-padding: 2 10; -fx-background-radius: 10; -fx-font-size: 12;"/>
            </HBox>
            
            <TableView fx:id="tableProjets" prefHeight="350" style="-fx-background-color: transparent;">
                <columns>
                    <TableColumn fx:id="colProjet" text="Nom du Projet" prefWidth="250" />
                    <TableColumn fx:id="colType" text="Type" prefWidth="100" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            </TableView>
        </VBox>
    </HBox>
</VBox>
