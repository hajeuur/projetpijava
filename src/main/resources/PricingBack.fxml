<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connection3a36.controllers.PricingBackController"
      spacing="25" style="-fx-background-color: #f8fafc;" prefWidth="1000" prefHeight="800">
    <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox HBox.hgrow="ALWAYS">
            <Label text="Gestion des Revenus" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="Visualisation des transactions via l'API Stripe" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/>
        </VBox>
        <Button text="🔄 Actualiser" onAction="#refreshTransactions"
                style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
        <Button text="🔗 Dashboard Stripe" onAction="#openStripeDashboard"
                style="-fx-background-color: #102c59; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand; -fx-font-weight: bold;"/>
    </HBox>

    <!-- Stats Cards -->
    <HBox spacing="20">
        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: #e2e8f0; -fx-border-width: 1;">
            <Label text="TOTAL TRANSACTIONS" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
            <Label fx:id="lblTotalCount" text="0" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #1e293b;"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: #e2e8f0; -fx-border-width: 1;">
            <Label text="VOLUME DE TRANSACTION" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
            <Label fx:id="lblTotalVolume" text="0,00 €" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #10b981;"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-left-color: #10b981; -fx-border-left-width: 4;">
            <Label text="RÉUSSIES" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
            <Label fx:id="lblSuccessCount" text="0" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #10b981;"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-left-color: #ef4444; -fx-border-left-width: 4;">
            <Label text="ÉCHOUÉES" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
            <Label fx:id="lblFailedCount" text="0" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #ef4444;"/>
        </VBox>
    </HBox>

    <!-- Table Section -->
    <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: #e2e8f0; -fx-border-width: 1;">
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #102c59; -fx-background-radius: 12 12 0 0; -fx-padding: 15 20;">
            <Label text="💳 Historique des Paiements" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="● Live Mode" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
        </HBox>
        <TableView fx:id="tblTransactions" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-width: 0;">
            <columns>
                <TableColumn fx:id="colId" text="ID TRANSACTION" prefWidth="250"/>
                <TableColumn fx:id="colClient" text="CLIENT / EMAIL" prefWidth="250"/>
                <TableColumn fx:id="colDesc" text="DESCRIPTION" prefWidth="200"/>
                <TableColumn fx:id="colAmount" text="MONTANT" prefWidth="120"/>
                <TableColumn fx:id="colStatus" text="STATUT" prefWidth="120"/>
            </columns>
            <placeholder>
                <Label text="Chargement des transactions Stripe..."/>
            </placeholder>
        </TableView>
    </VBox>
</VBox>
