<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.mentorai.Controller.TacheShowController"
            prefWidth="700" prefHeight="450"
            style="-fx-background-color: #f4f7fb;">
    <top>
        <VBox style="-fx-background-color: #102c59;">
            <padding><Insets top="20" left="30" right="30" bottom="20"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button text="← Retour" onAction="#handleRetour"
                        style="-fx-background-color: transparent; -fx-text-fill: #9dbbce; -fx-cursor: hand;"/>
                <Label text="Détail de la tâche"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="20">
            <padding><Insets top="30" left="40" right="40" bottom="30"/></padding>
            <VBox spacing="15"
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 35; -fx-effect: dropshadow(gaussian, rgba(16,44,89,0.08), 15, 0, 0, 5);">

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="ordreLabel" text=""
                           style="-fx-background-color: #102c59; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 50; -fx-padding: 8 14 8 14; -fx-font-size: 16px;"/>
                    <Label fx:id="titreLabel" text=""
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #102c59;"/>
                </HBox>

                <VBox spacing="4">
                    <Label text="Description :" style="-fx-font-weight: bold; -fx-text-fill: #102c59;"/>
                    <Label fx:id="descriptionLabel" text=""
                           style="-fx-text-fill: #666;" wrapText="true"/>
                </VBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="État :" style="-fx-font-weight: bold; -fx-text-fill: #102c59;"/>
                    <Label fx:id="etatLabel" text=""
                           style="-fx-font-weight: bold; -fx-background-radius: 50; -fx-padding: 5 15 5 15;"/>
                </HBox>

                <Separator/>

                <HBox spacing="15" alignment="CENTER">
                    <Button text="✏ Modifier" onAction="#handleEdit" prefWidth="150" prefHeight="40"
                            style="-fx-background-color: #fffbeb; -fx-text-fill: #d97706; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
                    <Button text="🗑 Supprimer" onAction="#handleDelete" prefWidth="150" prefHeight="40"
                            style="-fx-background-color: #fef2f2; -fx-text-fill: #dc2626; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
                    <Button text="← Retour" onAction="#handleRetour" prefWidth="150" prefHeight="40"
                            style="-fx-background-color: #102c59; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 50; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>